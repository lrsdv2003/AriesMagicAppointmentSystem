@model IEnumerable<AriesMagicAppointmentSystem.Models.Service>

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Archived Services";
}

<div class="dashboard-stats">
    <div class="stat-card">
        <div class="stat-label">Archived Services</div>
        <div class="stat-value">@Model.Count()</div>
        <div class="stat-subtext">Packages currently hidden from the client booking list.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Restore Ready</div>
        <div class="stat-value">Yes</div>
        <div class="stat-subtext">Archived services can be reactivated anytime.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Control</div>
        <div class="stat-value">Staff</div>
        <div class="stat-subtext">Use restore to make a service bookable again.</div>
    </div>
</div>

<div class="page-header">
    <div>
        <h1>Archived Services</h1>
        <p class="page-subtitle">Review and restore previously archived service packages.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">Back to Active</a>
    </div>
</div>

<div class="table-clean">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Duration</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
            <tr>
                <td>@item.Name</td>
                <td>₱@item.Price.ToString("N2")</td>
                <td>@item.DurationInHours hour(s)</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Details</a>
                    <a asp-action="Restore" asp-route-id="@item.Id" class="btn btn-sm btn-success">Restore</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>