@model IEnumerable<AriesMagicAppointmentSystem.Models.Service>

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Archived Packages";
}

<div class="page-header">
    <div>
        <h1>Archived Packages</h1>
        <p class="page-subtitle">Review archived packages and restore them when needed.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Active Packages</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>No archived packages</h3>
        <p>There are currently no archived packages in the system.</p>
    </div>
}
else
{
    <div class="package-grid">
        @foreach (var item in Model)
        {
            <div class="package-card archived-package-card">
                <div class="package-card-top">
                    <div>
                        <h3 class="package-card-title">@item.Name</h3>
                        <div class="package-card-badge archived-badge">Archived Package</div>
                    </div>
                    <div class="package-card-price">
                        ₱@item.Price.ToString("N2")
                    </div>
                </div>

                <div class="package-card-meta">
                    <div class="package-meta-box">
                        <span class="package-meta-label">Duration</span>
                        <span class="package-meta-value">@item.DurationInHours hour(s)</span>
                    </div>
                    <div class="package-meta-box">
                        <span class="package-meta-label">Status</span>
                        <span class="package-meta-value">Archived</span>
                    </div>
                </div>

                <div class="package-card-body">
                    <p class="package-card-description">
                        @(string.IsNullOrWhiteSpace(item.Description) ? "No description available for this package yet." : item.Description)
                    </p>
                </div>

                <div class="package-card-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light package-btn-light">Details</a>
                    <a asp-action="Restore" asp-route-id="@item.Id" class="btn btn-success">Restore</a>
                </div>
            </div>
        }
    </div>
}