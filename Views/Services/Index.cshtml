@model IEnumerable<AriesMagicAppointmentSystem.Models.Service>

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Packages";
}

<div class="page-header">
    <div>
        <h1>Packages</h1>
        <p class="page-subtitle">Manage your event packages, pricing, duration, and package inclusions.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">Create Package</a>
        <a asp-action="Archived" class="btn btn-outline-secondary">Archived Packages</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>No active packages yet</h3>
        <p>There are currently no active packages available in the system.</p>
    </div>
}
else
{
    <div class="package-grid">
        @foreach (var item in Model)
        {
            <div class="package-card">
                <div class="package-card-top">
                    <div>
                        <h3 class="package-card-title">@item.Name</h3>
                        <div class="package-card-badge">Active Package</div>
                    </div>
                    <div class="package-card-price">
                        ₱@item.Price.ToString("N2")
                    </div>
                </div>

                <div class="package-card-meta">
                    <div class="package-meta-box">
                        <span class="package-meta-label">Duration</span>
                        <span class="package-meta-value">@item.DurationInHours hour(s)</span>
                    </div>
                    <div class="package-meta-box">
                        <span class="package-meta-label">Status</span>
                        <span class="package-meta-value">Active</span>
                    </div>
                </div>

                <div class="package-card-body">
                    <p class="package-card-description">
                        @(string.IsNullOrWhiteSpace(item.Description) ? "No description available for this package yet." : item.Description)
                    </p>
                </div>

                <div class="package-card-actions">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light package-btn-light">Details</a>
                    <a asp-action="Archive" asp-route-id="@item.Id" class="btn btn-danger">Archive</a>
                </div>
            </div>
        }
    </div>
}