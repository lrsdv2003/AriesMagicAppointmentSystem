@model IEnumerable<AriesMagicAppointmentSystem.Models.Service>

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Services";
}

<div class="dashboard-stats">
    <div class="stat-card">
        <div class="stat-label">Active Services</div>
        <div class="stat-value">@Model.Count()</div>
        <div class="stat-subtext">Currently available packages for clients to book.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Management</div>
        <div class="stat-value">Staff</div>
        <div class="stat-subtext">Create, edit, archive, and restore service offerings.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Availability</div>
        <div class="stat-value">Live</div>
        <div class="stat-subtext">Visible services are ready for booking selection.</div>
    </div>
</div>

<div class="page-header">
    <div>
        <h1>Active Services</h1>
        <p class="page-subtitle">Manage the service packages available to clients.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">Create New Service</a>
        <a asp-action="Archived" class="btn btn-secondary">Archived Services</a>
    </div>
</div>

<div class="table-clean">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Duration</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
            <tr>
                <td>@item.Name</td>
                <td>₱@item.Price.ToString("N2")</td>
                <td>@item.DurationInHours hour(s)</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Details</a>
                    <a asp-action="Archive" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Archive</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>