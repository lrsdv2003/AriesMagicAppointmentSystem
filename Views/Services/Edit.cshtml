@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
@model AriesMagicAppointmentSystem.Models.Service

@{
    ViewData["Title"] = "Edit Service";
}

<div class="page-header">
    <div>
        <h1>Edit Service</h1>
        <p class="page-subtitle">Update service details.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="IsArchived" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="DurationInHours" class="form-label"></label>
            <input asp-for="DurationInHours" class="form-control" />
            <span asp-validation-for="DurationInHours" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}