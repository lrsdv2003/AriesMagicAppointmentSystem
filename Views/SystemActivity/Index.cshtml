@model AriesMagicAppointmentSystem.ViewModels.SystemActivityIndexViewModel
@using AriesMagicAppointmentSystem.Models

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "System Activity History";
}


<div class="dashboard-panel mb-4">
    <form method="get" asp-action="Index">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            
            <!-- Direct Search Input -->
            <div class="flex-grow-1" style="max-width: 400px;">
                <div class="input-group">
                    <span class="input-group-text bg-white text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="search" value="@Model?.SearchFilter" class="form-control border-start-0"
                           placeholder="Search action, user, record..." />
                </div>
            </div>

            <!-- Floating Filter Popover Dropdown -->
            <div class="dropdown filter-dropdown-wrapper">
                <button class="btn btn-outline-secondary dropdown-toggle d-flex align-items-center gap-2" 
                        type="button" 
                        id="filterDropdown" 
                        data-bs-toggle="dropdown" 
                        data-bs-auto-close="outside" 
                        aria-expanded="false">
                    <i class="bi bi-funnel"></i>
                    <span>Filters</span>
                    @if (Model != null && (Model.TypeFilter.HasValue || Model.FromDateFilter.HasValue || Model.ToDateFilter.HasValue))
                    {
                        <span class="filter-active-dot"></span>
                    }
                </button>

                <!-- Floating Card Content -->
                <div class="dropdown-menu dropdown-menu-end filter-popover-menu" aria-labelledby="filterDropdown">
                    <h6 class="fw-bold mb-3">Filter Activities</h6>
                    
                    <div class="mb-3">
                        <label class="form-label">Activity Type</label>
                        <select name="type" class="form-select form-select-sm">
                            <option value="">All Types</option>
                            @if (Model?.ActivityTypes != null)
                            {
                                foreach (var t in Model.ActivityTypes)
                                {
                                    <option value="@((int)t)" selected="@(Model.TypeFilter == t)">@t</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">From Date</label>
                        <input type="date" name="fromDate" value="@(Model?.FromDateFilter?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">To Date</label>
                        <input type="date" name="toDate" value="@(Model?.ToDateFilter?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
                    </div>

                    <hr class="my-3" />

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light btn-sm">Reset</a>
                        <button type="submit" class="btn btn-primary btn-sm">Apply Filters</button>
                    </div>
                </div>
            </div>

            <!-- Quick Submit & Clear -->
            <button type="submit" class="btn btn-primary">Search</button>
            
            @if (Model != null && (!string.IsNullOrEmpty(Model.SearchFilter) || Model.TypeFilter.HasValue || Model.FromDateFilter.HasValue || Model.ToDateFilter.HasValue))
            {
                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted">Clear all</a>
            }
        </div>
    </form>
</div>

<div class="dashboard-panel">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h3 class="mb-1">Activity Log</h3>
            <p class="page-subtitle mb-0">Showing @(Model?.Activities?.Count ?? 0) of @(Model?.TotalCount ?? 0) activities.</p>
        </div>
    </div>

    @if (Model?.Activities == null || !Model.Activities.Any())
    {
        <div class="empty-state">
            <i class="bi bi-activity"></i>
            <h3>No activity recorded</h3>
            
        </div>
    }
    else
    {
        <div class="table-clean">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th style="width: 120px;">Time</th>
                        <th>Action</th>
                        <th>Performed By</th>
                        <th>Affected Record</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var activity in Model.Activities)
                    {
                        var badgeClass = activity.Type switch
                        {
                            SystemActivityType.UserCreated => "bg-success",
                            SystemActivityType.UserDisabled => "bg-danger",
                            SystemActivityType.UserEnabled => "bg-success",
                            SystemActivityType.ServiceCreated => "bg-primary",
                            SystemActivityType.ServiceUpdated => "bg-info",
                            SystemActivityType.ServiceArchived => "bg-warning text-dark",
                            SystemActivityType.ServiceRestored => "bg-success",
                            SystemActivityType.CalendarModified => "bg-primary",
                            SystemActivityType.SettingsChanged => "bg-secondary",
                            SystemActivityType.BookingArchived => "bg-info",
                            SystemActivityType.PaymentVerified => "bg-success",
                            SystemActivityType.PaymentRejected => "bg-danger",
                            SystemActivityType.RefundApproved => "bg-success",
                            SystemActivityType.RefundRejected => "bg-danger",
                            SystemActivityType.RescheduleApproved => "bg-success",
                            SystemActivityType.RescheduleRejected => "bg-danger",
                            _ => "bg-secondary"
                        };

                        <tr>
                            <td class="text-nowrap small">@activity.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</td>
                            <td>
                                <span class="badge @badgeClass me-2">@activity.Type</span>
                                <div class="d-inline">@activity.Description</div>
                            </td>
                            <td>@activity.PerformedByUserName</td>
                            <td>
                                @if (!string.IsNullOrEmpty(activity.AffectedRecordType))
                                {
                                    <div class="small">
                                        <strong>@activity.AffectedRecordType</strong>
                                        @if (!string.IsNullOrEmpty(activity.AffectedRecordId))
                                        {
                                            <span class="text-muted"> #@activity.AffectedRecordId</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-muted small">
                                @if (!string.IsNullOrEmpty(activity.MetadataJson))
                                {
                                    @activity.MetadataJson
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@p"
                               asp-route-type="@(Model.TypeFilter?.ToString("d"))"
                               asp-route-fromDate="@(Model.FromDateFilter?.ToString("yyyy-MM-dd"))"
                               asp-route-toDate="@(Model.ToDateFilter?.ToString("yyyy-MM-dd"))"
                               asp-route-search="@Model.SearchFilter">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>