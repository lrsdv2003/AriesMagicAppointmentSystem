@model AriesMagicAppointmentSystem.ViewModels.RoleDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "_DashboardLayout";
}

<div class="staff-dashboard-heading">
    <span class="role-dashboard-eyebrow">Staff workspace</span>
    <h2>Dashboard</h2>
</div>

<div class="dashboard-two-column staff-activity-grid">
    <section class="dashboard-list-panel">
        <div class="dashboard-list-heading">
            <div>
                <span class="role-dashboard-eyebrow"><i class="bi bi-journal-plus me-1"></i>Incoming</span>
                <h3>Booking Requests Activity</h3>
            </div>
            <a asp-controller="Bookings" asp-action="Index">View all</a>
        </div>

        @if (!Model.RecentBookingRequests.Any())
        {
            <div class="dashboard-empty-state">
                <i class="bi bi-inbox"></i>
                <p>No booking requests available.</p>
            </div>
        }
        else
        {
            <div class="dashboard-record-list">
                @foreach (var booking in Model.RecentBookingRequests)
                {
                    <div class="dashboard-activity-row">
                        <div class="dashboard-record-icon"><i class="bi bi-calendar-plus"></i></div>
                        <div class="dashboard-record-copy">
                            <strong>@(booking.Client?.FullName ?? "Unknown client")</strong>
                            <span>@(booking.Service?.Name ?? booking.PackageName)</span>
                            <small>Event @booking.EventDate.ToString("MMM dd, yyyy") • Submitted @booking.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                        <span class="dashboard-status-pill">@booking.Status</span>
                        <a asp-controller="Bookings" asp-action="Details" asp-route-id="@booking.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                    </div>
                }
            </div>
        }
    </section>

    <section class="dashboard-list-panel">
        <div class="dashboard-list-heading">
            <div>
                <span class="role-dashboard-eyebrow"><i class="bi bi-calendar2-week me-1"></i>Changes</span>
                <h3>Reschedule Requests Activity</h3>
            </div>
            <a asp-controller="RescheduleRequests" asp-action="Index">View all</a>
        </div>

        @if (!Model.RecentRescheduleRequests.Any())
        {
            <div class="dashboard-empty-state">
                <i class="bi bi-calendar2-x"></i>
                <p>No reschedule requests available.</p>
            </div>
        }
        else
        {
            <div class="dashboard-record-list">
                @foreach (var request in Model.RecentRescheduleRequests)
                {
                    <div class="dashboard-activity-row">
                        <div class="dashboard-record-icon"><i class="bi bi-arrow-left-right"></i></div>
                        <div class="dashboard-record-copy">
                            <strong>@(request.Booking?.Client?.FullName ?? "Unknown client")</strong>
                            <span>@(request.Booking?.Service?.Name ?? request.Booking?.PackageName ?? "Package not available")</span>
                            <small>@(request.Booking?.EventDate.ToString("MMM dd, yyyy") ?? "N/A") → @request.RequestedDate.ToString("MMM dd, yyyy") • Submitted @request.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                        <span class="dashboard-status-pill">@request.Status</span>
                        <a asp-controller="RescheduleRequests" asp-action="Index" class="btn btn-sm btn-outline-primary">View Details</a>
                    </div>
                }
            </div>
        }
    </section>
</div>
