@model AriesMagicAppointmentSystem.ViewModels.RoleDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "_DashboardLayout";
}

<div class="role-dashboard-hero">
    <div>
        <span class="role-dashboard-eyebrow">Business overview</span>
        <h2>Welcome back, Owner</h2>
        <p>
            Monitor business activity, financial requests,
            booking performance, and upcoming events.
        </p>
    </div>

    <a asp-controller="Reports"
       asp-action="Index"
       class="btn btn-primary">
        <i class="bi bi-bar-chart-line me-1"></i>
        Open Reports
    </a>
</div>

<div class="dashboard-stat-grid">
    <a asp-controller="Bookings"
       asp-action="Index"
       class="dashboard-stat-card stat-info">
        <span class="dashboard-stat-icon"><i class="bi bi-journals"></i></span>
        <span class="dashboard-stat-label">Total Bookings</span>
        <strong>@Model.TotalBookings</strong>
        <small>All booking records</small>
    </a>

    <div class="dashboard-stat-card stat-success">
        <span class="dashboard-stat-icon"><i class="bi bi-cash-stack"></i></span>
        <span class="dashboard-stat-label">Verified Revenue</span>
        <strong>₱@Model.VerifiedRevenue.ToString("N2")</strong>
        <small>Verified payments only</small>
    </div>

    <a asp-controller="Payments"
       asp-action="PendingVerification"
       class="dashboard-stat-card stat-warning">
        <span class="dashboard-stat-icon"><i class="bi bi-hourglass-split"></i></span>
        <span class="dashboard-stat-label">Pending Requests</span>
        <strong>@(Model.PendingPayments + Model.PendingRefunds + Model.PendingReschedules)</strong>
        <small>Payments, refunds, and reschedules</small>
    </a>

    <a asp-controller="Bookings"
       asp-action="Index"
       class="dashboard-stat-card stat-neutral">
        <span class="dashboard-stat-icon"><i class="bi bi-check2-circle"></i></span>
        <span class="dashboard-stat-label">Completed Appointments</span>
        <strong>@Model.CompletedBookings</strong>
        <small>Finished event records</small>
    </a>
</div>

<div class="dashboard-stat-grid dashboard-stat-grid-compact">
    <a asp-controller="Payments"
       asp-action="PendingVerification"
       class="dashboard-stat-card stat-warning">
        <span class="dashboard-stat-label">Payments to Verify</span>
        <strong>@Model.PendingPayments</strong>
        <small>Requires Owner decision</small>
    </a>

    <a asp-controller="Payments"
       asp-action="RefundRequests"
       class="dashboard-stat-card stat-danger">
        <span class="dashboard-stat-label">Refund Requests</span>
        <strong>@Model.PendingRefunds</strong>
        <small>Pending review</small>
    </a>

    <a asp-controller="RescheduleRequests"
       asp-action="Index"
       class="dashboard-stat-card stat-info">
        <span class="dashboard-stat-label">Reschedule Requests</span>
        <strong>@Model.PendingReschedules</strong>
        <small>Awaiting final decision</small>
    </a>

    <div class="dashboard-stat-card stat-neutral">
        <span class="dashboard-stat-label">Revenue This Month</span>
        <strong>₱@Model.CurrentMonthRevenue.ToString("N2")</strong>
        <small>Current month verified payments</small>
    </div>
</div>

<div class="dashboard-two-column">
    <partial name="_RecentBookings" model="Model" />
    <partial name="_UpcomingEvents" model="Model" />
</div>
