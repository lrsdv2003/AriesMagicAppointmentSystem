@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aries Magic Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AriesMagicAppointmentSystem.styles.css" asp-append-version="true" />
</head>
<body class="dashboard-body">
    <div class="dashboard-shell">
        <aside class="dashboard-sidebar">
            <div>
                <div class="sidebar-brand">
                    <a asp-controller="Home" asp-action="Index">Aries Magic</a>
                </div>

                

                <nav class="sidebar-nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Staff"))
                        {
                            <a asp-controller="Dashboard" asp-action="Staff"
                               class="sidebar-link @(currentController == "Dashboard" ? "active" : "")">
                                <i class="bi bi-grid-1x2-fill"></i>
                                Dashboard
                            </a>
                            <a asp-controller="Bookings" asp-action="Index"
                               class="sidebar-link @(currentController == "Bookings" ? "active" : "")">
                                Bookings
                            </a>
                            <a asp-controller="Calendar" asp-action="Index"
                               class="sidebar-link @(currentController == "Calendar" ? "active" : "")">
                                Calendar
                            </a>

                            <a asp-controller="Services" asp-action="Index"
                            class="sidebar-link @(currentController == "Services" ? "active" : "")">
                                Packages
                            </a>

                            <a asp-controller="RescheduleRequests" asp-action="Index"
                               class="sidebar-link @(currentController == "RescheduleRequests" ? "active" : "")">
                                Reschedules
                            </a>

                            <a asp-controller="History" asp-action="Index"
                               class="sidebar-link @(currentController == "History" ? "active" : "")">
                                History
                            </a>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Dashboard" asp-action="Admin"
                               class="sidebar-link @(currentController == "Dashboard" ? "active" : "")">
                                <i class="bi bi-grid-1x2-fill"></i>
                                Dashboard
                            </a>

                            <a asp-controller="UserManagement" asp-action="Index"
                               class="sidebar-link @(currentController == "UserManagement" ? "active" : "")">
                                <i class="bi bi-people-fill me-2"></i>
                                User Management
                            </a>

                            <a asp-controller="Calendar" asp-action="Index"
                               class="sidebar-link @(currentController == "Calendar" ? "active" : "")">
                                <i class="bi bi-calendar3"></i>
                                Calendar
                            </a>

                            <a asp-controller="Services" asp-action="Index"
                               class="sidebar-link @(currentController == "Services" ? "active" : "")">
                                <i class="bi bi-box-seam"></i>
                                Packages
                            </a>

                            <a asp-controller="TrashHistory" asp-action="Index"
                               class="sidebar-link @(currentController == "TrashHistory" ? "active" : "")">
                                <i class="bi bi-trash"></i>
                                Trash History
                            </a>

                            <a asp-controller="SystemActivity" asp-action="Index"
                               class="sidebar-link @(currentController == "SystemActivity" ? "active" : "")">
                                <i class="bi bi-activity"></i>
                                System Activity
                            </a>
                        }

                        @if (User.IsInRole("Owner"))
                        {
                            <a asp-controller="Dashboard" asp-action="Owner"
                               class="sidebar-link @(currentController == "Dashboard" ? "active" : "")">
                                <i class="bi bi-grid-1x2-fill"></i>
                                Dashboard
                            </a>

                            <a asp-controller="Payments" asp-action="PendingVerification"
                               class="sidebar-link @(currentController == "Payment" && currentAction == "PendingVerification" ? "active" : "")">
                                <i class="bi bi-credit-card-2-front"></i>
                                Verify Payments
                            </a>

                            <a asp-controller="Payments" asp-action="RefundRequests"
                               class="sidebar-link @(currentController == "Payment" && currentAction == "RefundRequests" ? "active" : "")">
                                <i class="bi bi-arrow-counterclockwise"></i>
                                Refund Requests
                            </a>
                            
                            <a asp-controller="Calendar" asp-action="Index"
                               class="sidebar-link @(currentController == "Calendar" ? "active" : "")">
                                <i class="bi bi-calendar3"></i>
                                Calendar
                            </a>

                            <a asp-controller="History" asp-action="Index"
                               class="sidebar-link @(currentController == "History" ? "active" : "")">
                                <i class="bi bi-clock-history"></i>
                                History
                            </a>

                            <a asp-controller="Reports" asp-action="Index"
                               class="sidebar-link @(currentController == "Reports" ? "active" : "")">
                                <i class="bi bi-bar-chart-line"></i>
                                Reports
                            </a>
                        }
                    }
                </nav>
            </div>
        </aside>

        <main class="dashboard-main">
            <header class="dashboard-topbar">
                <div class="topbar-left">
                    <h1 class="dashboard-title">@ViewData["Title"]</h1>
                </div>

                <div class="topbar-right">
                    @inject AriesMagicAppointmentSystem.Data.ApplicationDbContext _context
                    @using System.Security.Claims
                    @{
                        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                        var unreadNotificationCount = 0;
                        if (!string.IsNullOrEmpty(currentUserId))
                        {
                            unreadNotificationCount = _context.Notifications 
                            .Count(n => n.UserId == currentUserId && !n.IsRead);
                        }
                    }
                   <a asp-controller="Notifications"
                        asp-action="Index"
                        class="topbar-icon topbar-bell"
                        title="Notifications">

                            <i class="bi bi-bell-fill"></i>

                            @if (unreadNotificationCount > 0)
                            {
                                <span class="notification-badge">
                                    @unreadNotificationCount
                                </span>
                            }
                    </a>
                    <button type="button" class="topbar-icon" title="Settings">
                    <i class="bi bi-gear-fill"></i>
                    </button>

                    @{
                        var userRole = "User";
                        if (User.IsInRole("Owner"))
                        {
                            userRole = "Owner";
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            userRole = "Admin";
                        }
                        else if (User.IsInRole("Staff"))
                        {
                            userRole = "Staff";
                        }
                    }

                    <div class="topbar-user-dropdown">
                        <div class="topbar-user-text">
                            <div class="topbar-user-name">@userRole User</div>
                            <div class="topbar-user-email">@User.Identity?.Name</div>
                        </div>

                        <div class="topbar-avatar">AM</div>

                        <button type="button"
                                class="topbar-logout-trigger"
                                title="Logout"
                                data-bs-toggle="modal"
                                data-bs-target="#logoutConfirmModal">
                            <i class="bi bi-box-arrow-right topbar-chevron"></i>
                        </button>
                    </div>
                </div>
            </header>

            <section class="dashboard-content">
                @RenderBody()

                <div class="modal fade" id="logoutConfirmModal" tabindex="-1" aria-labelledby="logoutConfirmModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content logout-modal">
                            <div class="modal-header">
                                <h5 class="modal-title" id="logoutConfirmModalLabel">Confirm Logout</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                Are you sure you want to logout?
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger">Logout</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toggle = document.getElementById("userMenuToggle");
            const menu = document.getElementById("userMenu");

            if (toggle && menu) {
                toggle.addEventListener("click", function (e) {
                    e.stopPropagation();
                    menu.classList.toggle("show");
                });

                document.addEventListener("click", function () {
                    menu.classList.remove("show");
                });

                menu.addEventListener("click", function (e) {
                    e.stopPropagation();
                });
            }
        });
    </script>
</body>
</html>