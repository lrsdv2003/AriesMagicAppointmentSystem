<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aries Magic Appointment System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AriesMagicAppointmentSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <ul class="navbar-nav ms-auto d-flex flex-row align-items-center gap-3">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
            </li>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                @if (User.IsInRole("Client"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Bookings" asp-action="MyBookings">My Bookings</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Bookings" asp-action="Create">Book Now</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Payments" asp-action="Upload">Upload Payment</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Payments" asp-action="MyUploads">My Payments</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="RescheduleRequests" asp-action="MyRequests">My Reschedules</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-notification-link" asp-controller="Notifications" asp-action="Index">Notifications</a>
                    </li>
                }

                <li class="nav-item">
                    <span class="nav-link">Hello, @User.Identity.Name</span>
                </li>
                <li class="nav-item">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-secondary btn-sm">Logout</button>
                    </form>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                </li>
            }
        </ul>
    </header>

    <main class="main-content">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="custom-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <h5>Aries Magic</h5>
                    <p class="footer-text">
                        Making celebrations more memorable through engaging event entertainment and a smooth online booking experience.
                    </p>
                </div>
                <div>
                    <h5>Quick Links</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Bookings" asp-action="Create">Book Now</a></li>
                        <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                    </ul>
                </div>
                <div>
                    <h5>Contact</h5>
                    <p class="footer-text">
                        For inquiries and booking support, clients may reach out through the platform and registered email updates.
                    </p>
                </div>
            </div>
            <div class="footer-bottom">
                &copy; 2026 - Aries Magic Appointment System
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>