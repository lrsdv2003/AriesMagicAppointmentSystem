@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aries Magic</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AriesMagicAppointmentSystem.styles.css" asp-append-version="true" />
</head>
<body class="client-body">
    <header class="client-navbar-wrap">
        <nav class="navbar navbar-expand-lg client-navbar">
            <div class="container">
                <a class="navbar-brand client-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">✨</span>
                    <span>Aries Magic</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#clientNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="clientNavbar">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 client-nav-links">
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index" asp-fragment="packages">Packages</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index" asp-fragment="how-it-works">How It Works</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Client"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Bookings" && currentAction == "MyBookings" ? "active" : "")"
                                   asp-controller="Bookings" asp-action="MyBookings">My Bookings</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Payments" && currentAction == "MyUploads" ? "active" : "")"
                                   asp-controller="Payments" asp-action="MyUploads">My Payments</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(currentController == "RescheduleRequests" && currentAction == "MyRequests" ? "active" : "")"
                                   asp-controller="RescheduleRequests" asp-action="MyRequests">My Reschedules</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Notifications" ? "active" : "")"
                                   asp-controller="Notifications" asp-action="Index">Notifications</a>
                            </li>
                        }
                    </ul>

                    <div class="client-nav-actions d-flex align-items-center gap-2">
                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Client"))
                        {
                            <a asp-controller="Bookings" asp-action="CreateStepOne" class="btn btn-primary">
                                Book Now
                            </a>

                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
                                Login
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary">
                                Create Account
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="client-main">
        @if (currentController == "Home" && currentAction == "Index")
        {
            @RenderBody()
        }
        else
        {
            <div class="container client-page-wrap">
                @RenderBody()
            </div>
        }
    </main>

    <footer class="client-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <div class="footer-brand">
                        <span class="brand-mark">✨</span>
                        <span>Aries Magic</span>
                    </div>
                    <p class="footer-text">
                        Bringing fun, wonder, and memorable entertainment experiences to birthdays,
                        school events, company gatherings, and special celebrations.
                    </p>
                </div>

                <div>
                    <h5>Quick Links</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Home" asp-action="Index" asp-fragment="packages">Packages</a></li>
                        <li><a asp-controller="Bookings" asp-action="CreateStepOne">Book Now</a></li>
                        <li><a asp-controller="Account" asp-action="Register">Create Account</a></li>
                    </ul>
                </div>

                <div>
                    <h5>Booking Process</h5>
                    <p class="footer-text">
                        Create an account, fill out your event details, choose your package,
                        upload your payment proof, and monitor your booking updates online.
                    </p>
                </div>

                <div>
                    <h5>Events We Cater</h5>
                    <ul class="footer-links">
                        <li>Birthday</li>
                        <li>Company Events</li>
                        <li>School Events</li>
                        <li>Christmas Parties</li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <span>&copy; 2026 Aries Magic Appointment System. All rights reserved.</span>
                <span>Designed for a smooth and modern client booking experience.</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>