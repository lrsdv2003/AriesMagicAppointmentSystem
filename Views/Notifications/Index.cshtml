@model IEnumerable<AriesMagicAppointmentSystem.Models.Notification>

@{
    ViewData["Title"] = "Notifications";
}

<div class="page-header">
    <div>
        <h1>Notifications</h1>
        <p class="page-subtitle">Your recent system updates and alerts.</p>
    </div>
</div>

<div class="table-clean">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Status</th>
                <th>Title</th>
                <th>Message</th>
                <th>Date</th>
                <th class="text-end">Action</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
            <tr>
                <td>
                    @if (item.IsRead)
                    {
                        <span class="status-badge">Read</span>
                    }
                    else
                    {
                        <span class="status-badge">Unread</span>
                    }
                </td>
                <td>@item.Title</td>
                <td>@item.Message</td>
                <td>@item.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                <td class="text-end">
                    <a asp-action="Open" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Open</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>