@model AriesMagicAppointmentSystem.ViewModels.PaymentUploadViewModel

@{
    ViewData["Title"] = "Upload Payment";
}

<div class="page-header">
    <div>
        <h1>Upload Payment</h1>
        <p class="page-subtitle">Submit downpayment proof for a booking awaiting payment.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Upload">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="BookingId" class="form-label"></label>
            <select asp-for="BookingId" asp-items="Model.Bookings" class="form-control">
                <option value="">-- Select Booking --</option>
            </select>
            <span asp-validation-for="BookingId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Amount" class="form-label"></label>
            <input asp-for="Amount" class="form-control" />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ProofImagePath" class="form-label"></label>
            <input asp-for="ProofImagePath" class="form-control" placeholder="example: /uploads/payment1.jpg" />
            <span asp-validation-for="ProofImagePath" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Upload Payment</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}