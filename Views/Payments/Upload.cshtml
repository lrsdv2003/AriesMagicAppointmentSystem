@model AriesMagicAppointmentSystem.ViewModels.PaymentUploadViewModel

@{
    ViewData["Title"] = "Upload Payment";
}

<div class="client-portal-header">
    <div>
        <div class="section-kicker">Client Portal</div>
        <h1 class="client-portal-title">Upload Payment</h1>
        <p class="client-portal-text">
            Pay the fixed downpayment, scan the GCash QR code, then upload your payment proof for admin verification.
        </p>
    </div>
</div>

<div class="am-wizard-tracker am-static-tracker mb-4">
    <div class="am-wizard-node is-active" data-node="1">
        <span class="am-wizard-node-dot">1</span>
        <span class="am-wizard-node-label">Upload Proof</span>
    </div>
    <div class="am-wizard-node is-upcoming" data-node="2">
        <span class="am-wizard-node-dot">2</span>
        <span class="am-wizard-node-label">Admin Review</span>
    </div>
    <div class="am-wizard-node is-upcoming" data-node="3">
        <span class="am-wizard-node-dot">3</span>
        <span class="am-wizard-node-label">Verified &amp; Confirmed</span>
    </div>
</div>

<div class="upload-payment-layout">
    <div class="dashboard-panel">
        <div class="form-section-title mb-1">Payment Information</div>
        <p class="page-subtitle mb-4">The required downpayment is fixed at ₱2,000.00.</p>

        <form asp-action="Upload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="BookingId" class="form-label">Select Booking</label>
                    <select asp-for="BookingId" asp-items="Model.Bookings" class="form-select">
                        <option value="">-- Select Booking --</option>
                    </select>
                    <span asp-validation-for="BookingId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Required Downpayment</label>
                    <input value="₱@Model.FixedDownpaymentAmount.ToString("N2")" class="form-control" readonly />
                    <div class="form-text">This amount is fixed and cannot be changed by the client.</div>
                </div>

                <div class="col-md-6">
                    <label asp-for="ProofImage" class="form-label">Payment Proof</label>
                    <input asp-for="ProofImage" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                    <span asp-validation-for="ProofImage" class="text-danger"></span>
                    <div class="form-text mt-2">Accepted formats: JPG, JPEG, PNG, WEBP. Max size: 5MB.</div>
                </div>
            </div>

            <div class="payment-form-note mt-4">
                Make sure the uploaded screenshot or receipt is clear, complete, and readable to avoid rejection or delays in verification.
            </div>

            <div class="upload-payment-actions">
                <button type="submit" class="btn btn-primary btn-lg">Submit Payment Proof</button>
                <a asp-action="RequestRefund" class="btn btn-outline-danger btn-lg">Request Refund</a>
                <a asp-action="MyUploads" class="btn btn-outline-secondary btn-lg">Back to My Payments</a>
            </div>
        </form>
    </div>

    <div class="dashboard-panel payment-guide-panel">
        <div class="form-section-title mb-1">GCash Payment QR</div>
        <p class="page-subtitle mb-4">Scan this QR code to send the fixed downpayment.</p>

        <div class="text-center mb-4">
            <img src="@Model.GCashQrPath"
                 alt="GCash QR Code"
                 style="max-width: 320px; width: 100%; border-radius: 18px; border: 1px solid #e5e7eb;" />
        </div>

        <div class="payment-guide-note mt-4">
            Required downpayment: <strong>₱@Model.FixedDownpaymentAmount.ToString("N2")</strong>
        </div>

        <div class="payment-guide-list mt-4">
            <div class="payment-guide-card">
                <div class="payment-guide-icon">1</div>
                <div>
                    <strong>Scan the GCash QR</strong>
                    <p>Use GCash to send the fixed downpayment amount.</p>
                </div>
            </div>

            <div class="payment-guide-card">
                <div class="payment-guide-icon">2</div>
                <div>
                    <strong>Take a screenshot</strong>
                    <p>Save a clear proof of payment after sending the money.</p>
                </div>
            </div>

            <div class="payment-guide-card">
                <div class="payment-guide-icon">3</div>
                <div>
                    <strong>Upload proof</strong>
                    <p>Submit your screenshot and wait for admin verification.</p>
                </div>
            </div>

            <div class="payment-guide-card">
                <div class="payment-guide-icon">4</div>
                <div>
                    <strong>Refund option</strong>
                    <p>If you sent money but your slot was already taken, submit a refund request.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}