@model AriesMagicAppointmentSystem.Models.Payment

@{
    ViewData["Title"] = "Reject Payment";
}

<div class="page-header">
    <div>
        <h1>Reject Payment</h1>
        <p class="page-subtitle">Reject this payment proof and return booking to awaiting downpayment.</p>
    </div>
</div>

<div class="form-card">
    <dl class="row details-list mb-4">
        <dt class="col-sm-3">Client</dt>
        <dd class="col-sm-9">@Model.Booking?.Client?.FullName</dd>

        <dt class="col-sm-3">Service</dt>
        <dd class="col-sm-9">@Model.Booking?.Service?.Name</dd>

        <dt class="col-sm-3">Amount</dt>
        <dd class="col-sm-9">₱@Model.Amount.ToString("N2")</dd>

        <dt class="col-sm-3">Proof</dt>
        <dd class="col-sm-9">
            <img src="@Model.ProofImagePath" alt="Payment Proof" style="max-width: 300px; border-radius: 12px;" /></dd>
    </dl>

    <form asp-action="Reject">
        <input type="hidden" asp-for="Id" />

        <div class="mb-4">
            <label class="form-label">Rejection Reason</label>
            <textarea name="rejectionReason" class="form-control" rows="4"></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Reject Payment</button>
            <a asp-action="PendingVerification" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>