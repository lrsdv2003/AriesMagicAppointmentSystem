@model IEnumerable<AriesMagicAppointmentSystem.Models.Booking>

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Pending Bookings";
}

<div class="dashboard-stats">
    <div class="stat-card">
        <div class="stat-label">Pending Requests</div>
        <div class="stat-value">@Model.Count()</div>
        <div class="stat-subtext">Bookings currently awaiting staff action.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Action Needed</div>
        <div class="stat-value">Now</div>
        <div class="stat-subtext">Review booking details and proceed with approval or decline.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Workflow Stage</div>
        <div class="stat-value">Staff</div>
        <div class="stat-subtext">This page is for booking review and first approval.</div>
    </div>
</div>

<div class="page-header">
    <div>
        <h1>Pending Bookings</h1>
        <p class="page-subtitle">Review and process new booking requests submitted by clients.</p>
    </div>
</div>

<div class="table-clean">
    <table class="table align-middle">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <h3>No records yet</h3>
                <p>There is nothing to display here right now.</p>
            </div>
        }
        else
        {
            <div class="table-clean">
                <table class="table align-middle">
                    ...
                </table>
            </div>
        }
        <thead>
            <tr>
                <th>Client</th>
                <th>Service</th>
                <th>Date</th>
                <th>Start</th>
                <th>End</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
    var statusClass = item.Status switch
                {
                    "Pending" => "status-pending",
                    "AwaitingDownpayment" => "status-awaiting",
                    "AwaitingVerification" => "status-awaiting",
                    "Confirmed" => "status-confirmed",
                    "Completed" => "status-completed",
                    "Declined" => "status-declined",
                    "Expired" => "status-expired",
                    _ => "status-read"
                };
            <tr>
                <td>@item.Client?.FullName</td>
                <td>@item.Service?.Name</td>
                <td>@item.EventDate.ToString("MMM dd, yyyy")</td>
                <td>@item.StartTime.ToString("hh:mm tt")</td>
                <td>@item.EndTime.ToString("hh:mm tt")</td>
                <td>
                        <span class="status-badge @statusClass">@item.Status</span>
                    </td>
                <td class="text-end">
                    <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success">Approve</a>
                    <a asp-action="Decline" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Decline</a>
                    <a asp-action="AddNote" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Add Note</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>