@model AriesMagicAppointmentSystem.ViewModels.BookingStepTwoViewModel

@{
    ViewData["Title"] = "Create Booking - Step 2";
    ViewData["WizardPhysicalStep"] = 2;
    ViewData["WizardSubStep"] = 1;
}

<partial name="_BookingWizardTracker" />

<div class="page-header">
    <div>
        <h1>Create Booking</h1>
        <p class="page-subtitle">Choose your package, review the inclusions, then confirm your booking.</p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["Error"]</div>
}

<div class="dashboard-panel mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <div class="form-section-title mb-1">Event Summary</div>
            <p class="page-subtitle mb-0">Review the details you entered in Step 1 before choosing a package.</p>
        </div>
        <a asp-action="CreateStepOne" class="btn btn-outline-secondary btn-sm">Edit Step 1</a>
    </div>

    <div class="row g-3">
        @if (!string.IsNullOrWhiteSpace(Model.EventType))
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Event Type</span>
                    <span class="package-meta-value">@Model.EventType</span>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Motif))
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Motif</span>
                    <span class="package-meta-value">@Model.Motif</span>
                </div>
            </div>
        }

        @if (Model.EventDate != default)
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Event Date</span>
                    <span class="package-meta-value">
                        @Model.EventDate.ToString("MMMM dd, yyyy")
                    </span>
                </div>
            </div>
        }

        @if (Model.StartTime != default)
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Start Time</span>
                    <span class="package-meta-value">
                        @DateTime.Today.Add(Model.StartTime).ToString("hh:mm tt")
                    </span>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.PartyTheme))
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Party Theme</span>
                    <span class="package-meta-value">@Model.PartyTheme</span>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.PartyVenue))
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Venue</span>
                    <span class="package-meta-value">@Model.PartyVenue</span>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.CelebrantName))
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Celebrant</span>
                    <span class="package-meta-value">@Model.CelebrantName</span>
                </div>
            </div>
        }

        @if (Model.Age.HasValue && Model.Age.Value > 0)
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Age</span>
                    <span class="package-meta-value">@Model.Age</span>
                </div>
            </div>
        }

        @if (Model.PaxCount > 0)
        {
            <div class="col-md-4">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Number of Guests</span>
                    <span class="package-meta-value">@Model.PaxCount</span>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ContactPerson))
        {
            <div class="col-md-6">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Contact Person</span>
                    <span class="package-meta-value">@Model.ContactPerson</span>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ContactNumber))
        {
            <div class="col-md-6">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Contact Number</span>
                    <span class="package-meta-value">@Model.ContactNumber</span>
                </div>
            </div>
        }
    </div>
</div>

<form asp-controller="Bookings" asp-action="SubmitBooking" method="post" id="bookingStepTwoForm">
    @Html.AntiForgeryToken()

    <input asp-for="EventType" type="hidden" />
    <input asp-for="Motif" type="hidden" />
    <input asp-for="EventDate" type="hidden" />
    <input asp-for="StartTime" type="hidden" />
    <input asp-for="PartyTheme" type="hidden" />
    <input asp-for="PartyVenue" type="hidden" />
    <input asp-for="CelebrantName" type="hidden" />
    <input asp-for="Age" type="hidden" />
    <input asp-for="PaxCount" type="hidden" />
    <input asp-for="ContactPerson" type="hidden" />
    <input asp-for="ContactNumber" type="hidden" />
    <input asp-for="BasePrice" type="hidden" id="basePriceInput" />
    <input asp-for="FinalPrice" type="hidden" id="finalPriceInput" />
    <input asp-for="RequiredDownpayment" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <!-- PANEL 3: PACKAGE & CUSTOMIZE -->
    <div class="am-panel" id="panelPackage" data-panel-index="3">
        <div class="dashboard-panel mb-4">
            <div class="form-section-title mb-3">Select Package</div>

            <div class="package-selector-wrap">
                <select asp-for="ServiceId"
                        class="form-select package-selector-dropdown"
                        onchange="window.location.href='@Url.Action("CreateStepTwo", "Bookings")?serviceId=' + this.value">
                    @foreach (var packageItem in Model.AvailablePackages)
                    {
                        <option value="@packageItem.Id">
                            @packageItem.Name - &#8369;@packageItem.Price.ToString("N2")
                        </option>
                    }
                </select>
            </div>

            <span asp-validation-for="ServiceId" class="text-danger"></span>
        </div>

        <div class="booking-package-layout">
            <div class="dashboard-panel">
                <div class="package-preview-header">
                    <div>
                        <div class="package-card-badge">Selected Package</div>
                        <h3 class="package-preview-title mt-2">@Model.PackageName</h3>
                        <p class="page-subtitle mb-0">
                            Review the inclusions below. You can remove up to 2 removable inclusions only.
                        </p>
                    </div>

                    <div class="package-preview-price">&#8369;@Model.BasePrice.ToString("N2")</div>
                </div>

                <div class="package-preview-summary mt-4">
                    <div class="package-meta-box">
                        <span class="package-meta-label">Base Price</span>
                        <span class="package-meta-value">&#8369;@Model.BasePrice.ToString("N2")</span>
                    </div>

                    <div class="package-meta-box">
                        <span class="package-meta-label">Required Downpayment</span>
                        <span class="package-meta-value">&#8369;2,000.00</span>
                    </div>
                </div>

                <div class="mt-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                        <div>
                            <div class="form-section-title mb-1">Package Inclusions</div>
                            <p class="page-subtitle mb-0">
                                Uncheck removable inclusions to reduce the final package cost.
                                Removing one or two inclusions gives a fixed total deduction of &#8369;2,000.00.
                            </p>
                        </div>
                    </div>

                    <div class="booking-summary-note mb-3">
                        Fixed inclusions cannot be removed. You can remove up to <strong>2 inclusions only</strong>.
                        Removing one or two inclusions gives a fixed total deduction of <strong>&#8369;2,000.00</strong>.
                        The required downpayment stays at <strong>&#8369;2,000.00</strong>.
                    </div>

                    <div id="removedInclusionLimitWarning" class="alert alert-warning d-none mb-3">
                        You can only remove up to 2 inclusions.
                    </div>

                    <div id="removedInputsContainer"></div>

                    <div class="booking-inclusion-list">
                        @for (int i = 0; i < Model.Inclusions.Count; i++)
                        {
                            <div class="booking-inclusion-card">
                                <div class="booking-inclusion-main">
                                    <div>
                                        <div class="booking-inclusion-name">@Model.Inclusions[i].Name</div>

                                        <div class="booking-inclusion-deduction">
                                            @if (Model.Inclusions[i].IsRemovable)
                                            {
                                                <span>Eligible for fixed &#8369;2,000.00 total deduction</span>
                                            }
                                            else
                                            {
                                                <span>No deduction available</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="booking-inclusion-action">
                                        @if (Model.Inclusions[i].IsRemovable)
                                        {
                                            <div class="form-check form-switch">
                                                @if (Model.Inclusions[i].IsSelected)
                                                {
                                                    <input class="form-check-input inclusion-checkbox"
                                                           type="checkbox"
                                                           data-name="@Model.Inclusions[i].Name"
                                                           value="@Model.Inclusions[i].Id"
                                                           checked />
                                                }
                                                else
                                                {
                                                    <input class="form-check-input inclusion-checkbox"
                                                           type="checkbox"
                                                           data-name="@Model.Inclusions[i].Name"
                                                           value="@Model.Inclusions[i].Id" />
                                                }

                                                <label class="form-check-label">Included</label>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-read">Fixed Inclusion</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <input type="hidden" name="Inclusions[@i].Id" value="@Model.Inclusions[i].Id" />
                            <input type="hidden" name="Inclusions[@i].Name" value="@Model.Inclusions[i].Name" />
                            <input type="hidden" name="Inclusions[@i].DeductionAmount" value="@(Model.Inclusions[i].IsRemovable ? "2000" : "0")" />
                            <input type="hidden" name="Inclusions[@i].IsRemovable" value="@(Model.Inclusions[i].IsRemovable ? "true" : "false")" />
                            <input type="hidden" name="Inclusions[@i].IsSelected" value="@(Model.Inclusions[i].IsSelected ? "true" : "false")" />
                        }
                    </div>
                </div>
            </div>

            <div class="dashboard-panel booking-price-panel">
                <div class="form-section-title mb-3">Booking Summary</div>
                <p class="page-subtitle mb-3">
                    This summary updates automatically based on the inclusions you keep or remove.
                </p>

                <div class="booking-price-row">
                    <span>Base Price</span>
                    <strong>&#8369;<span id="basePriceText">@Model.BasePrice.ToString("N2")</span></strong>
                </div>

                <div class="booking-price-row">
                    <span>Total Deduction</span>
                    <strong>&#8369;<span id="deductionText">0.00</span></strong>
                </div>

                <div class="booking-price-row booking-total-row">
                    <span>Final Price</span>
                    <strong>&#8369;<span id="finalPriceText">@Model.FinalPrice.ToString("N2")</span></strong>
                </div>

                <div class="booking-price-row">
                    <span>Required Downpayment</span>
                    <strong>&#8369;2,000.00</strong>
                </div>

                <div class="am-panel-nav">
                    <a asp-action="CreateStepOne" class="btn btn-outline-secondary">Back to Step 1</a>
                    <button type="button" class="btn btn-primary" id="goToReviewBtn">Continue to Review</button>
                </div>
            </div>
        </div>
    </div>

    <!-- PANEL 4: REVIEW & CONFIRM -->
    <div class="am-panel" id="panelReview" data-panel-index="4" hidden>
        <div class="dashboard-panel">
            <div class="form-section-title mb-3">Review &amp; Confirm</div>
            <p class="page-subtitle mb-4">Double-check your final amount and package before submitting your booking.</p>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Package</span>
                        <span class="package-meta-value" id="reviewPackageName">@Model.PackageName</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Removed Inclusions</span>
                        <span class="package-meta-value" id="reviewRemovedInclusions">None</span>
                    </div>
                </div>
            </div>

            <div class="booking-price-row">
                <span>Base Price</span>
                <strong>&#8369;<span id="reviewBasePriceText">@Model.BasePrice.ToString("N2")</span></strong>
            </div>
            <div class="booking-price-row">
                <span>Total Deduction</span>
                <strong>&#8369;<span id="reviewDeductionText">0.00</span></strong>
            </div>
            <div class="booking-price-row booking-total-row">
                <span>Final Price</span>
                <strong>&#8369;<span id="reviewFinalPriceText">@Model.FinalPrice.ToString("N2")</span></strong>
            </div>
            <div class="booking-price-row">
                <span>Required Downpayment</span>
                <strong>&#8369;2,000.00</strong>
            </div>

            <div class="booking-summary-note mt-3 mb-4">
                Please review the final amount carefully before submitting your booking request.
                You must agree to the Terms &amp; Agreement to submit.
            </div>

            <div class="am-panel-nav">
                <button type="button" class="btn btn-outline-secondary" id="backToPackageBtn">Back to Package</button>

                <button type="button"
                        class="btn btn-primary"
                        data-bs-toggle="modal"
                        data-bs-target="#termsAgreementModal">
                    Submit Booking
                </button>
            </div>
        </div>
    </div>

    <div class="modal fade" id="termsAgreementModal" tabindex="-1" aria-labelledby="termsAgreementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content agreement-modal formal-agreement-modal">

            <div class="agreement-formal-header">
                <div class="agreement-document-icon">
                    <i class="bi bi-file-earmark-check"></i>
                </div>

                <div>
                    <h5 id="termsAgreementModalLabel">Terms & Agreement</h5>
                    <p>
                        Please read the following terms carefully. By submitting your booking,
                        you agree to abide by these terms and conditions.
                    </p>
                </div>

                <button type="button" class="btn-close agreement-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="agreement-formal-body">

                <div class="agreement-term-row">
                    <div class="agreement-term-icon">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                    <div class="agreement-term-content">
                        <h6>1. Downpayment</h6>
                        <p>
                            A &#8369;2,000 downpayment is required to secure your reservation.
                            The remaining balance will be paid after the event.
                        </p>
                    </div>
                </div>

                <div class="agreement-term-row">
                    <div class="agreement-term-icon">
                        <i class="bi bi-calendar-x"></i>
                    </div>
                    <div class="agreement-term-content">
                        <h6>2. Cancellation Policy</h6>
                        <p>
                            The client must notify the service provider at least two (2) weeks
                            before the event. Late cancellation may forfeit reimbursement.
                        </p>
                    </div>
                </div>

                <div class="agreement-term-row">
                    <div class="agreement-term-icon">
                        <i class="bi bi-calendar2-week"></i>
                    </div>
                    <div class="agreement-term-content">
                        <h6>3. Rescheduling</h6>
                        <p>
                            Rescheduling due to emergencies, restrictions, or Acts of God
                            is subject to availability.
                        </p>
                    </div>
                </div>

                <div class="agreement-term-row">
                    <div class="agreement-term-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <div class="agreement-term-content">
                        <h6>4. Service Guarantee</h6>
                        <p>
                            The service provider shall render the agreed service on the confirmed
                            event date and time.
                        </p>
                    </div>
                </div>

                <div class="agreement-term-row">
                    <div class="agreement-term-icon">
                        <i class="bi bi-camera"></i>
                    </div>
                    <div class="agreement-term-content">
                        <h6>5. Media Permission</h6>
                        <p>
                            Photos and videos from the event will only be published after receiving
                            approval from the client.
                        </p>
                    </div>
                </div>

                <div class="agreement-policy-highlight">
                    <div class="agreement-policy-icon">
                        <i class="bi bi-award"></i>
                    </div>

                    <div>
                        <h6>Implementation of First Payment, First Get</h6>
                        <p>
                            Schedules are not reserved until the downpayment is successfully submitted.
                            If multiple clients choose the same schedule, the earliest client to submit
                            a valid payment proof will secure the schedule.
                        </p>
                        <strong>
                            First payment first get — the earliest submitted payment secures the schedule.
                        </strong>
                    </div>
                </div>

                <div class="agreement-formal-confirm">
                    <input asp-for="AcceptTerms"
                           class="form-check-input"
                           type="checkbox"
                           id="AcceptTerms"
                           form="bookingStepTwoForm" />

                    <label for="AcceptTerms">
                        I have read, understood, and agree to the
                        <strong>Terms & Agreement</strong> stated above.
                    </label>
                </div>

                <span asp-validation-for="AcceptTerms" class="text-danger"></span>
            </div>

            <div class="agreement-formal-footer">
                <button type="button" class="btn btn-light agreement-cancel-btn" data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="submit"
                        class="btn agreement-submit-btn"
                        id="confirmSubmitBookingBtn"
                        form="bookingStepTwoForm"
                        disabled>
                    I Agree & Submit Booking
                </button>
            </div>
        </div>
    </div>
</div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const maxRemovedInclusions = 2;
        const fixedDeductionPerInclusion = 2000;

        function currentRemovedNames() {
            return Array.from(document.querySelectorAll(".inclusion-checkbox:not(:checked)"))
                .map(cb => cb.getAttribute("data-name"));
        }

        function syncRemovedInclusions(changedCheckbox = null) {
            const removedInputsContainer = document.getElementById("removedInputsContainer");
            const warningBox = document.getElementById("removedInclusionLimitWarning");

            if (!removedInputsContainer) {
                return;
            }

            const checkboxes = document.querySelectorAll(".inclusion-checkbox");
            const removedCheckboxes = Array.from(checkboxes).filter(cb => !cb.checked);

            if (removedCheckboxes.length > maxRemovedInclusions) {
                if (changedCheckbox) {
                    changedCheckbox.checked = true;
                }

                if (warningBox) {
                    warningBox.classList.remove("d-none");
                    warningBox.textContent = "You can only remove up to 2 inclusions.";
                }

                return syncRemovedInclusions();
            }

            if (warningBox) {
                if (removedCheckboxes.length >= maxRemovedInclusions) {
                    warningBox.classList.remove("d-none");
                    warningBox.textContent = "Maximum removed inclusions reached. You can only remove up to 2 inclusions.";
                } else {
                    warningBox.classList.add("d-none");
                    warningBox.textContent = "";
                }
            }

            removedInputsContainer.innerHTML = "";

            const validRemovedCheckboxes = Array.from(checkboxes).filter(cb => !cb.checked);

            validRemovedCheckboxes.forEach(cb => {
                const hidden = document.createElement("input");
                hidden.type = "hidden";
                hidden.name = "RemovedInclusionIds";
                hidden.value = cb.value;
                removedInputsContainer.appendChild(hidden);
            });

            const totalDeduction = validRemovedCheckboxes.length > 0
                ? fixedDeductionPerInclusion
                : 0;

            const basePriceInput = document.getElementById("basePriceInput");
            const finalPriceInput = document.getElementById("finalPriceInput");
            const deductionText = document.getElementById("deductionText");
            const finalPriceText = document.getElementById("finalPriceText");

            const basePrice = parseFloat(basePriceInput?.value || "0");
            const finalPrice = Math.max(basePrice - totalDeduction, 0);

            if (deductionText) {
                deductionText.textContent = totalDeduction.toLocaleString(undefined, {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            }

            if (finalPriceText) {
                finalPriceText.textContent = finalPrice.toLocaleString(undefined, {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            }

            if (finalPriceInput) {
                finalPriceInput.value = finalPrice.toFixed(2);
            }
        }

        function updateTermsState() {
            const acceptTerms = document.getElementById("AcceptTerms");
            const confirmBtn = document.getElementById("confirmSubmitBookingBtn");
            const errorSpan = document.getElementById("acceptTermsError");

            if (!acceptTerms || !confirmBtn) {
                return;
            }

            confirmBtn.disabled = !acceptTerms.checked;

            if (acceptTerms.checked && errorSpan) {
                errorSpan.textContent = "";
                errorSpan.style.display = "none";
                errorSpan.classList.remove("field-validation-error");
                errorSpan.classList.add("field-validation-valid");
            }

            if (!acceptTerms.checked && errorSpan) {
                errorSpan.style.display = "block";
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const checkboxes = document.querySelectorAll(".inclusion-checkbox");

            checkboxes.forEach(cb => {
                cb.addEventListener("change", function () {
                    syncRemovedInclusions(this);
                });
            });

            syncRemovedInclusions();

            const acceptTerms = document.getElementById("AcceptTerms");
            const form = document.getElementById("bookingStepTwoForm");

            updateTermsState();

            if (acceptTerms) {
                acceptTerms.addEventListener("change", updateTermsState);
            }

            if (form) {
                form.addEventListener("submit", function (e) {
                    const removedCount = document.querySelectorAll(".inclusion-checkbox:not(:checked)").length;

                    if (removedCount > maxRemovedInclusions) {
                        e.preventDefault();

                        const warningBox = document.getElementById("removedInclusionLimitWarning");

                        if (warningBox) {
                            warningBox.classList.remove("d-none");
                            warningBox.textContent = "You can only remove up to 2 inclusions.";
                        }

                        return;
                    }

                    if (acceptTerms && !acceptTerms.checked) {
                        e.preventDefault();

                        const errorSpan = document.getElementById("acceptTermsError");

                        if (errorSpan) {
                            errorSpan.textContent = "You must agree to the Terms and Agreement before submitting your booking.";
                            errorSpan.style.display = "block";
                            errorSpan.classList.remove("field-validation-valid");
                            errorSpan.classList.add("field-validation-error");
                        }
                    }
                });
            }

            // ---- internal 2-panel mini-wizard for this physical step ----
            const panelPackage = document.getElementById("panelPackage");
            const panelReview = document.getElementById("panelReview");
            const goToReviewBtn = document.getElementById("goToReviewBtn");
            const backToPackageBtn = document.getElementById("backToPackageBtn");
            const tracker = document.getElementById("ariesWizardTracker");

            function setTrackerActive(nodeIndex) {
                if (!tracker) return;
                tracker.querySelectorAll(".am-wizard-node").forEach(function (node) {
                    const idx = parseInt(node.getAttribute("data-node"), 10);
                    node.classList.remove("is-active", "is-done", "is-upcoming");
                    if (idx < nodeIndex) node.classList.add("is-done");
                    else if (idx === nodeIndex) node.classList.add("is-active");
                    else node.classList.add("is-upcoming");

                    const dot = node.querySelector(".am-wizard-node-dot");
                    if (dot) dot.innerHTML = idx < nodeIndex ? '<i class="bi bi-check-lg"></i>' : idx;
                });
            }

            function populateReview() {
                document.getElementById("reviewPackageName").textContent =
                    document.querySelector(".package-preview-title")?.textContent.trim() || "";

                document.getElementById("reviewBasePriceText").textContent =
                    document.getElementById("basePriceText")?.textContent || "0.00";
                document.getElementById("reviewDeductionText").textContent =
                    document.getElementById("deductionText")?.textContent || "0.00";
                document.getElementById("reviewFinalPriceText").textContent =
                    document.getElementById("finalPriceText")?.textContent || "0.00";

                const removedNames = currentRemovedNames();
                document.getElementById("reviewRemovedInclusions").textContent =
                    removedNames.length > 0 ? removedNames.join(", ") : "None";
            }

            if (goToReviewBtn) {
                goToReviewBtn.addEventListener("click", function () {
                    populateReview();
                    panelPackage.hidden = true;
                    panelReview.hidden = false;
                    setTrackerActive(4);
                    panelReview.scrollIntoView({ behavior: "smooth", block: "start" });
                });
            }

            if (backToPackageBtn) {
                backToPackageBtn.addEventListener("click", function () {
                    panelReview.hidden = true;
                    panelPackage.hidden = false;
                    setTrackerActive(3);
                    panelPackage.scrollIntoView({ behavior: "smooth", block: "start" });
                });
            }
        });
    </script>
}
