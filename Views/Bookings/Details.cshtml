@model AriesMagicAppointmentSystem.Models.Booking
@using System.Text.Json

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Booking Details";

    List<string> removedInclusions = new();

    if (!string.IsNullOrWhiteSpace(Model.RemovedInclusionsJson))
    {
        try
        {
            removedInclusions = JsonSerializer.Deserialize<List<string>>(Model.RemovedInclusionsJson) ?? new List<string>();
        }
        catch
        {
            removedInclusions = new List<string>();
        }
    }

    var latestPayment = Model.Payments?
        .OrderByDescending(p => p.UploadedAt)
        .FirstOrDefault();

    var bookingStatusClass = Model.Status switch
    {
        "Pending" => "status-pending",
        "AwaitingDownpayment" => "status-awaiting",
        "AwaitingVerification" => "status-awaiting",
        "Confirmed" => "status-confirmed",
        "Completed" => "status-completed",
        "Declined" => "status-declined",
        "Expired" => "status-expired",
        _ => "status-read"
    };

    var paymentStatusClass = latestPayment?.Status switch
    {
        "Pending" => "status-pending",
        "Verified" => "status-verified",
        "Rejected" => "status-rejected",
        _ => "status-read"
    };
}

<div class="page-header">
    <div>
        <h1>Booking Details</h1>
        <p class="page-subtitle">Review the full booking information, package summary, payment status, and internal notes.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Bookings</a>
    </div>
</div>

<div class="dashboard-stats mb-4">
    <div class="stat-card">
        <div class="stat-label">Booking ID</div>
        <div class="stat-value">BK-@Model.CreatedAt.Year-@Model.Id.ToString("D3")</div>
        <div class="stat-subtext">Reference number for this booking.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Booking Status</div>
        <div class="stat-value">
            <span class="status-badge @bookingStatusClass">@Model.Status</span>
        </div>
        <div class="stat-subtext">Current workflow status of this reservation.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Latest Payment</div>
        <div class="stat-value">
            @if (latestPayment == null)
            {
                <span class="status-badge status-read">No Payment</span>
            }
            else
            {
                <span class="status-badge @paymentStatusClass">@latestPayment.Status</span>
            }
        </div>
        <div class="stat-subtext">Most recent payment verification result.</div>
    </div>
</div>

<div class="booking-details-layout">
    <div class="dashboard-panel">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
                <div class="form-section-title mb-1">
                    Client & Event Information
                </div>

                <p class="page-subtitle mb-0">
                    Complete details submitted by the client during booking.
                </p>
            </div>
        </div>

        <div class="row g-3">

            @if (!string.IsNullOrWhiteSpace(Model.Client?.FullName))
            {
                <div class="col-md-6">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Client Name</span>
                        <span class="package-meta-value">
                            @Model.Client.FullName
                        </span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Client?.Email))
            {
                <div class="col-md-6">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Client Email</span>
                        <span class="package-meta-value">
                            @Model.Client.Email
                        </span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.EventType))
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Event Type</span>
                        <span class="package-meta-value">
                            @Model.EventType
                        </span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Motif))
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Motif</span>
                        <span class="package-meta-value">
                            @Model.Motif
                        </span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.PartyTheme))
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Party Theme</span>
                        <span class="package-meta-value">
                            @Model.PartyTheme
                        </span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.PartyVenue))
            {
                <div class="col-md-6">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Party Venue</span>
                        <span class="package-meta-value">
                            @Model.PartyVenue
                        </span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.CelebrantName))
            {
                <div class="col-md-3">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Celebrant Name</span>
                        <span class="package-meta-value">
                            @Model.CelebrantName
                        </span>
                    </div>
                </div>
            }

            @if (Model.Age.HasValue && Model.Age.Value > 0)
            {
                <div class="col-md-3">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Age</span>
                        <span class="package-meta-value">
                            @Model.Age
                        </span>
                    </div>
                </div>
            }

            @if (Model.PaxCount > 0)
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Guests / Pax</span>
                        <span class="package-meta-value">
                            @Model.PaxCount
                        </span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ContactPerson))
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Contact Person</span>
                        <span class="package-meta-value">
                            @Model.ContactPerson
                        </span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ContactNumber))
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Contact Number</span>
                        <span class="package-meta-value">
                            @Model.ContactNumber
                        </span>
                    </div>
                </div>
            }

            @if (Model.EventDate != default)
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Event Date</span>
                        <span class="package-meta-value">
                            @Model.EventDate.ToString("MMMM dd, yyyy")
                        </span>
                    </div>
                </div>
            }

            @if (Model.StartTime != default)
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">Start Time</span>
                        <span class="package-meta-value">
                            @Model.StartTime.ToString("hh:mm tt")
                        </span>
                    </div>
                </div>
            }

            @if (Model.EndTime != default)
            {
                <div class="col-md-4">
                    <div class="package-meta-box h-100">
                        <span class="package-meta-label">End Time</span>
                        <span class="package-meta-value">
                            @Model.EndTime.ToString("hh:mm tt")
                        </span>
                    </div>
                </div>
            }

        </div>
    </div>

    <div class="dashboard-panel">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
                <div class="form-section-title mb-1">Package & Payment Summary</div>
                <p class="page-subtitle mb-0">Pricing, payment status, and package customization details.</p>
            </div>
        </div>

        <div class="booking-price-row">
            <span>Selected Package</span>
            <strong>@Model.PackageName</strong>
        </div>

        <div class="booking-price-row">
            <span>Base Price</span>
            <strong>₱@Model.BasePrice.ToString("N2")</strong>
        </div>

        <div class="booking-price-row booking-total-row">
            <span>Final Price</span>
            <strong>₱@Model.FinalPrice.ToString("N2")</strong>
        </div>

        <div class="booking-price-row">
            <span>Required Downpayment</span>
            <strong>₱@Model.RequiredDownpayment.ToString("N2")</strong>
        </div>

        <div class="booking-price-row">
            <span>Package Duration</span>
            <strong>@Model.Service?.DurationInHours hour(s)</strong>
        </div>

        <div class="booking-price-row">
            <span>Latest Payment Status</span>
            <strong>
                @if (latestPayment == null)
                {
                    <span class="status-badge status-read">No Payment</span>
                }
                else
                {
                    <span class="status-badge @paymentStatusClass">@latestPayment.Status</span>
                }
            </strong>
        </div>

        <div class="mt-4">
            <div class="form-section-title mb-2">Removed Inclusions</div>

            @if (!removedInclusions.Any())
            {
                <div class="empty-state small-empty-state">
                    <h3>No removed inclusions</h3>
                    <p>The client kept all available package inclusions.</p>
                </div>
            }
            else
            {
                <div class="removed-inclusion-list">
                    @foreach (var item in removedInclusions)
                    {
                        <div class="removed-inclusion-chip">@item</div>
                    }
                </div>
            }
        </div>

        <div class="mt-4">
            <div class="form-section-title mb-2">Internal Notes</div>

            @if (string.IsNullOrWhiteSpace(Model.InternalNotes))
            {
                <div class="empty-state small-empty-state">
                    <h3>No internal notes</h3>
                    <p>No internal notes have been added for this booking yet.</p>
                </div>
            }
            else
            {
                <div class="details-description-block">
                    @Model.InternalNotes
                </div>
            }
        </div>
    </div>
</div>

@{
    var isPending = Model.Status == AriesMagicAppointmentSystem.Models.BookingStatus.Pending;
    var isConfirmed = Model.Status == AriesMagicAppointmentSystem.Models.BookingStatus.Confirmed;
    var canComplete = isConfirmed && User.CanCompleteBookings();
    var hasPrimaryAction = isPending || canComplete;
}

@if (User.CanManageBookingRecords())
{
    <div class="dashboard-panel mt-4 booking-actions-panel">
        <div class="booking-actions-bar">
            <div class="booking-actions-info">
                <div class="form-section-title mb-1">Available Actions</div>
                <p class="page-subtitle mb-0">Only actions valid for the current status are shown.</p>
            </div>

            <div class="booking-actions-controls">
                @if (isPending)
                {
                    <a asp-action="Decline" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                        <i class="bi bi-x-lg"></i> Decline
                    </a>
                    <a asp-action="Approve" asp-route-id="@Model.Id" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Approve Booking
                    </a>
                }

                @if (canComplete)
                {
                    <a asp-action="Complete" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-flag-fill"></i> Mark as Completed
                    </a>
                }

                <div class="dropdown booking-actions-more">
                    <button type="button"
                            class="btn @(hasPrimaryAction ? "btn-outline-secondary" : "btn-secondary")"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            title="More actions">
                        <i class="bi bi-three-dots"></i>
                        <span>More Actions</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" asp-action="AddNote" asp-route-id="@Model.Id">
                                <i class="bi bi-journal-plus"></i> Add Internal Note
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}