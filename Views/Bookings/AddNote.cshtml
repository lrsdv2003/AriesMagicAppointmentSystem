@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
@model AriesMagicAppointmentSystem.Models.Booking

@{
    ViewData["Title"] = "Add Internal Note";
}

<div class="page-header">
    <div>
        <h1>Add Internal Note</h1>
        <p class="page-subtitle">Save a private staff note for this booking.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="AddNote">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Booking</label>
            <input class="form-control" value="@Model.Client?.FullName - @Model.Service?.Name" disabled />
        </div>

        <div class="mb-4">
            <label class="form-label">Internal Notes</label>
            <textarea name="internalNotes" class="form-control" rows="5">@Model.InternalNotes</textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Note</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>