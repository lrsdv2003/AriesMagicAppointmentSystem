@model IEnumerable<AriesMagicAppointmentSystem.Models.Booking>
@using AriesMagicAppointmentSystem.Models

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "All Bookings";
}

<div class="dashboard-stats">
    <div class="stat-card">
        <div class="stat-label">Total Bookings</div>
        <div class="stat-value">@Model.Count()</div>
        <div class="stat-subtext">All booking records currently stored in the system.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Confirmed</div>
        <div class="stat-value">@Model.Count(x => x.Status == BookingStatus.Confirmed)</div>
        <div class="stat-subtext">Bookings fully verified and confirmed.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Pending / Review</div>
        <div class="stat-value">@Model.Count(x => x.Status == BookingStatus.Pending || x.Status == BookingStatus.AwaitingVerification || x.Status == BookingStatus.AwaitingDownpayment)</div>
        <div class="stat-subtext">Requests still moving through the approval/payment process.</div>
    </div>
</div>

<div class="page-header">
    <div>
        <h1>All Bookings</h1>
        <p class="page-subtitle">Monitor all client bookings and their current workflow status.</p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Staff"))
        {
            <a asp-action="Pending" class="btn btn-secondary">Pending Bookings</a>
        }
    </div>
</div>

<div class="table-clean">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Client</th>
                <th>Service</th>
                <th>Event Date</th>
                <th>Start</th>
                <th>End</th>
                <th>Status</th>
                <th>Note</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
    var statusClass = item.Status switch
    {
        "Pending" => "status-pending",
        "AwaitingDownpayment" => "status-awaiting",
        "AwaitingVerification" => "status-awaiting",
        "Confirmed" => "status-confirmed",
        "Completed" => "status-completed",
        "Declined" => "status-declined",
        "Expired" => "status-expired",
        _ => "status-read"
    };
            <tr>
                <td>@item.Client?.FullName</td>
                <td>@item.Service?.Name</td>
                <td>@item.EventDate.ToString("MMM dd, yyyy")</td>
                <td>@item.StartTime.ToString("hh:mm tt")</td>
                <td>@item.EndTime.ToString("hh:mm tt")</td>
                <td><span class="status-badge">@item.Status</span></td>
                <td>@item.InternalNotes</td>
                <td class="text-end">
                    @if (User.IsInRole("Staff"))
                    {
                        <a asp-action="AddNote" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Note</a>

                        @if (item.Status == BookingStatus.Confirmed)
                        {
                            <a asp-action="Complete" asp-route-id="@item.Id" class="btn btn-sm btn-success">Complete</a>
                        }
                    }
                </td>
            </tr>
}
        </tbody>
    </table>
</div>