@model AriesMagicAppointmentSystem.ViewModels.BookingManagementViewModel

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Bookings";
}

<div class="page-header">
    <div>
        <h1>Booking Management</h1>
        <p class="page-subtitle">Search, filter, and manage all booking records in one place.</p>
    </div>
</div>

<div class="dashboard-panel mb-4">
    <form method="get" asp-action="Index">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" name="search" value="@Model.Search" class="form-control"
                       placeholder="Search by client, booking ID..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Booking Status</label>
                <select name="bookingStatus" class="form-select">
                    <option value="All" selected="@(Model.BookingStatus == "All")">All Status</option>
                    <option value="Pending" selected="@(Model.BookingStatus == "Pending")">Pending</option>
                    <option value="AwaitingDownpayment" selected="@(Model.BookingStatus == "AwaitingDownpayment")">Awaiting Downpayment</option>
                    <option value="AwaitingVerification" selected="@(Model.BookingStatus == "AwaitingVerification")">Awaiting Verification</option>
                    <option value="Confirmed" selected="@(Model.BookingStatus == "Confirmed")">Confirmed</option>
                    <option value="Completed" selected="@(Model.BookingStatus == "Completed")">Completed</option>
                    <option value="Declined" selected="@(Model.BookingStatus == "Declined")">Declined</option>
                    <option value="Expired" selected="@(Model.BookingStatus == "Expired")">Expired</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Payment Status</label>
                <select name="paymentStatus" class="form-select">
                    <option value="All" selected="@(Model.PaymentStatus == "All")">All Status</option>
                    <option value="No Payment" selected="@(Model.PaymentStatus == "No Payment")">No Payment</option>
                    <option value="Pending" selected="@(Model.PaymentStatus == "Pending")">Pending</option>
                    <option value="Verified" selected="@(Model.PaymentStatus == "Verified")">Verified</option>
                    <option value="Rejected" selected="@(Model.PaymentStatus == "Rejected")">Rejected</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-panel">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">All Bookings</h3>
            <p class="page-subtitle mb-0">Showing @Model.Bookings.Count booking(s)</p>
        </div>
    </div>

    @if (!Model.Bookings.Any())
    {
        <div class="empty-state">
            <h3>No bookings found</h3>
            <p>No booking records matched your current search and filters.</p>
        </div>
    }
    else
    {
        <div class="table-clean">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Booking ID</th>
                        <th>Client Name</th>
                        <th>Service</th>
                        <th>Event Date</th>
                        <th>Booking Status</th>
                        <th>Payment Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
@foreach (var item in Model.Bookings)
{
                    var bookingClass = item.BookingStatus switch
                    {
                        "Pending" => "status-pending",
                        "AwaitingDownpayment" => "status-awaiting",
                        "AwaitingVerification" => "status-awaiting",
                        "Confirmed" => "status-confirmed",
                        "Completed" => "status-completed",
                        "Declined" => "status-declined",
                        "Expired" => "status-expired",
                        _ => "status-read"
                    };

                    var paymentClass = item.PaymentStatus switch
                    {
                        "Pending" => "status-pending",
                        "Verified" => "status-verified",
                        "Rejected" => "status-rejected",
                        "No Payment" => "status-read",
                        _ => "status-read"
                    };

                    <tr>
                        <td>@item.BookingCode</td>
                        <td>@item.ClientName</td>
                        <td>@item.ServiceName</td>
                        <td>@item.EventDate.ToString("MMMM dd, yyyy")</td>
                        <td>
                            <span class="status-badge @bookingClass">@item.BookingStatus</span>
                        </td>
                        <td>
                            <span class="status-badge @paymentClass">@item.PaymentStatus</span>
                        </td>
                        <td class="text-end">
                            @if (User.IsInRole("Staff"))
                            {
                                if (item.BookingStatus == "Pending")
                                {
                                    <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success">Approve</a>
                                    <a asp-action="Decline" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Decline</a>
                                }

                                <a asp-action="AddNote" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Note</a>

                                if (item.BookingStatus == "Confirmed")
                                {
                                    <a asp-action="Complete" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Complete</a>
                                }
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Payments" asp-action="PendingVerification" class="btn btn-sm btn-secondary">Payments</a>
                            }
                        </td>
                    </tr>
}
                </tbody>
            </table>
        </div>
    }
</div>