@model AriesMagicAppointmentSystem.ViewModels.CalendarIndexViewModel
@using AriesMagicAppointmentSystem.Models
@using AriesMagicAppointmentSystem.Extensions

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Calendar";

    var blockedDatesJson = System.Text.Json.JsonSerializer.Serialize(ViewBag.BlockedDates ?? new List<object>());
    var dailyCountsJson = System.Text.Json.JsonSerializer.Serialize(ViewBag.DailyCounts ?? new Dictionary<string, int>());
    var dateLimitsJson = System.Text.Json.JsonSerializer.Serialize(ViewBag.DateLimits ?? new Dictionary<string, int>());
    var isAdmin = User.IsInRole("Admin");
}

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />


<div class="admin-calendar-page">
    <!-- Page Header -->
    <header class="admin-calendar-header">
        <div class="header-content">
           
            @if (User.IsInRole("Admin"))
            {
                <div class="header-actions">
                    <button type="button" class="btn btn-primary"
                            data-bs-toggle="modal"
                            data-bs-target="#manageCalendarModal">
                        <i class="bi bi-calendar2-gear me-1"></i>
                        <span>Manage Calendar</span>
                    </button>
                </div>
            }
        </div>
    </header>

    <!-- Stats Overview -->
    <section class="admin-calendar-stats" aria-label="Calendar statistics">
        <div class="stat-card">
            <div class="stat-icon blocked">
                <i class="bi bi-calendar-x"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">@Model.Manage.BlockedDates.Count</div>
                <div class="stat-label">Blocked Dates</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon limit">
                <i class="bi bi-calendar-limit"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">@Model.Manage.MaxBookingsPerDay</div>
                <div class="stat-label">Default Daily Limit</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon custom">
                <i class="bi bi-calendar-date"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">@Model.Manage.DateBookingLimits.Count</div>
                <div class="stat-label">Custom Date Limits</div>
            </div>
        </div>
    </section>

    <!-- Calendar Visualization -->
    <section class="admin-calendar-section" aria-label="Calendar view">
        <div class="calendar-header-bar">
            <div class="calendar-nav">
                <button type="button" class="btn btn-icon" id="calPrev" aria-label="Previous month">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button type="button" class="btn btn-icon" id="calNext" aria-label="Next month">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <button type="button" class="btn btn-icon" id="calToday" aria-label="Go to today">
                    <i class="bi bi-calendar-today"></i>
                </button>
            </div>
            <div class="calendar-title" id="calendarTitle"></div>
            <div class="calendar-legend">
                <span class="legend-item" data-legend="blocked">
                    <span class="legend-dot blocked"></span>
                    Blocked
                </span>
                <span class="legend-item" data-legend="limited">
                    <span class="legend-dot limited"></span>
                    Limited
                </span>
                <span class="legend-item" data-legend="event">
                    <span class="legend-dot event"></span>
                    Bookings
                </span>
            </div>
        </div>
        <div class="calendar-container">
            <div id="calendar"></div>
        </div>
    </section>

    <!-- Quick Reference Lists (Collapsible) -->
    <section class="admin-calendar-lists" aria-label="Quick reference lists">
        <div class="row g-3">
            <div class="col-lg-6">
                <div class="list-panel">
                    <div class="list-header">
                        <h3 class="list-title">
                            <i class="bi bi-calendar-x me-2"></i>
                            Blocked Dates
                        </h3>
                        <span class="list-count badge bg-secondary">@Model.Manage.BlockedDates.Count</span>
                    </div>
                    <div class="list-body">
                        @if (!Model.Manage.BlockedDates.Any())
                        {
                            <p class="list-empty">No blocked dates configured.</p>
                        }
                        else
                        {
                            <ul class="list-items">
                                @foreach (var item in Model.Manage.BlockedDates.OrderBy(x => x.Date))
                                {
                                    <li class="list-item" data-id="@item.Id">
                                        <div class="list-item-content">
                                            <time class="list-item-date" datetime="@item.Date.ToString("yyyy-MM-dd")">@item.Date.ToString("MMM dd, yyyy")</time>
                                            <span class="list-item-reason">@item.Reason</span>
                                        </div>
                                        <button type="button" class="btn btn-icon btn-ghost btn-sm delete-item" data-action="unblock" data-id="@item.Id" aria-label="Unblock @item.Date.ToString("MMM dd, yyyy")">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="list-panel">
                    <div class="list-header">
                        <h3 class="list-title">
                            <i class="bi bi-calendar-date me-2"></i>
                            Custom Date Limits
                        </h3>
                        <span class="list-count badge bg-secondary">@Model.Manage.DateBookingLimits.Count</span>
                    </div>
                    <div class="list-body">
                        @if (!Model.Manage.DateBookingLimits.Any())
                        {
                            <p class="list-empty">No custom limits configured.</p>
                        }
                        else
                        {
                            <ul class="list-items">
                                @foreach (var item in Model.Manage.DateBookingLimits.OrderBy(x => x.Date))
                                {
                                    <li class="list-item" data-id="@item.Id">
                                        <div class="list-item-content">
                                            <time class="list-item-date" datetime="@item.Date.ToString("yyyy-MM-dd")">@item.Date.ToString("MMM dd, yyyy")</time>
                                            <span class="list-item-limit">Max: @item.MaxBookings @(item.MaxBookings == 1 ? "booking" : "bookings")</span>
                                        </div>
                                        <button type="button" class="btn btn-icon btn-ghost btn-sm delete-item" data-action="removelimit" data-id="@item.Id" aria-label="Remove limit for @item.Date.ToString("MMM dd, yyyy")">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Manage Calendar Modal -->
<div class="modal fade" id="manageCalendarModal" tabindex="-1" aria-labelledby="manageCalendarModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="manageCalendarModalLabel">
                    <i class="bi bi-calendar2-gear me-2"></i>
                    Manage Calendar
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="manageMessage" class="alert d-none mb-3" role="alert"></div>

                <ul class="nav nav-tabs mb-4" id="manageTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="tab-daily" data-bs-toggle="tab" data-bs-target="#panel-daily" role="tab" aria-selected="true">
                            <i class="bi bi-calendar-check me-1"></i> Daily Limit
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-block" data-bs-toggle="tab" data-bs-target="#panel-block" role="tab" aria-selected="false">
                            <i class="bi bi-calendar-x me-1"></i> Block Date
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-custom" data-bs-toggle="tab" data-bs-target="#panel-custom" role="tab" aria-selected="false">
                            <i class="bi bi-calendar-date me-1"></i> Custom Limit
                        </button>
                    </li>
                </ul>

                <div class="tab-content">
                    <!-- Daily Limit Tab -->
                    <div class="tab-pane fade show active" id="panel-daily" role="tabpanel" aria-labelledby="tab-daily">
                        <form id="formDailyLimit"action="@Url.Action("UpdateMaxBookingsAjax", "Calendar")"method="post"class="needs-validation"novalidate>
                            @Html.AntiForgeryToken()
                            <div class="form-group">
                                <label for="MaxBookingsPerDay" class="form-label">Maximum Events Per Day</label>
                                <input type="number" class="form-control" id="MaxBookingsPerDay" name="MaxBookingsPerDay" min="1" value="@Model.Manage.MaxBookingsPerDay" required />
                                <div class="form-text">Default maximum number of bookings allowed per day. Can be overridden by date-specific limits.</div>
                                <div class="invalid-feedback">Please enter a valid number (minimum 1).</div>
                            </div>
                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save Limit</button>
                            </div>
                        </form>
                    </div>

                    <!-- Block Date Tab -->
                    <div class="tab-pane fade" id="panel-block" role="tabpanel" aria-labelledby="tab-block">
                        <form id="formBlockDate"action="@Url.Action("BlockDateAjax", "Calendar")"method="post"class="needs-validation"novalidate>
                            @Html.AntiForgeryToken()
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="BlockDate" class="form-label">Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" id="BlockDate" name="BlockDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                                    <div class="invalid-feedback">Please select a valid date (today or future).</div>
                                </div>
                            </div>
                            <div class="form-group mt-3">
                                <label for="BlockReason" class="form-label">Reason <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="BlockReason" name="BlockReason" rows="3" placeholder="Enter reason for blocking this date..." required></textarea>
                                <div class="invalid-feedback">Please provide a reason.</div>
                            </div>
                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger">Block Date</button>
                            </div>
                        </form>
                    </div>

                    <!-- Custom Limit Tab -->
                    <div class="tab-pane fade" id="panel-custom" role="tabpanel" aria-labelledby="tab-custom">
                        <form id="formCustomLimit"action="@Url.Action("SetDateLimitAjax", "Calendar")"method="post"class="needs-validation"novalidate>
                            @Html.AntiForgeryToken()
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="LimitDate" class="form-label">Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" id="LimitDate" name="LimitDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                                    <div class="invalid-feedback">Please select a valid date (today or future).</div>
                                </div>
                                <div class="col-md-6">
                                    <label for="LimitMaxBookings" class="form-label">Maximum Events <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control" id="LimitMaxBookings" name="LimitMaxBookings" min="0" required />
                                    <div class="form-text">Set to 0 to fully block the date.</div>
                                    <div class="invalid-feedback">Please enter a valid number (minimum 0).</div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save Custom Limit</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalLabel">Confirm Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="confirmMessage">Are you sure you want to proceed?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmAction">Delete</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>

@section Scripts {
    <script>
        (function() {
            'use strict';

            // Configuration from server
            const blockedDates = @Html.Raw(blockedDatesJson);
            const dailyCounts = @Html.Raw(dailyCountsJson);
            const dateLimits = @Html.Raw(dateLimitsJson);

            // State
            let calendar = null;
            let pendingDelete = { action: null, id: null };

            // Utility functions
            const formatDateKey = (date) => date.toISOString().split('T')[0];
            const formatDisplayDate = (date) => new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

            // Show toast/message
            function showMessage(success, message, containerId = 'manageMessage') {
                const box = document.getElementById(containerId);
                box.className = `alert ${success ? 'alert-success' : 'alert-danger'} mb-3`;
                box.textContent = message;
                box.classList.remove('d-none');
            }

            function hideMessage(containerId = 'manageMessage') {
                const box = document.getElementById(containerId);
                box.classList.add('d-none');
            }

            // Reload page keeping modal open if needed
            function reloadPage() {
                window.location.reload();
            }

            // Submit form via AJAX
            async function submitForm(formId, successMessage) {
            const form = document.getElementById(formId);
            if (!form) return false;

            hideMessage();

            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return false;
            }

            const formData = new FormData(form);

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });

                let data;

                try {
                    data = await response.json();
                } catch {
                    throw new Error(
                        `Server returned ${response.status} ${response.statusText}`
                    );
                }

                if (!response.ok) {
                    throw new Error(
                        data.message || `Request failed with status ${response.status}`
                    );
                }

                showMessage(
                    data.success,
                    data.message || successMessage
                );

                if (data.success) {
                    setTimeout(reloadPage, 700);
                    return true;
                }
            } catch (error) {
                console.error(`${formId} submission failed:`, error);

                showMessage(
                    false,
                    error.message || 'Something went wrong. Please try again.'
                );
            }

            return false;
        }

            // Delete action via AJAX
            async function deleteItem(action, id) {
                const actionMap = {
                    'unblock': { url: '/Calendar/UnblockDateAjax', message: 'Date unblocked successfully.' },
                    'removelimit': { url: '/Calendar/RemoveDateLimitAjax', message: 'Custom limit removed successfully.' }
                };

                const config = actionMap[action];
                if (!config) return false;

                try {
                    const formData = new FormData();
                    formData.append('id', id);

                    const response = await fetch(config.url, {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) throw new Error('Request failed');

                    const data = await response.json();
                    if (data.success) {
                        showMessage(true, config.message, 'pageMessage');
                        setTimeout(reloadPage, 700);
                        return true;
                    } else {
                        showMessage(false, data.message, 'pageMessage');
                    }
                } catch {
                    showMessage(false, 'Something went wrong. Please try again.', 'pageMessage');
                }
                return false;
            }

            // Initialize Calendar
            function initCalendar() {
                const calendarEl = document.getElementById('calendar');
                if (!calendarEl) return;

                // Build events from bookings
                const events = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(
                        (Model.Bookings ?? new List<Booking>()).Select(b => new {
                            id = b.Id,
                            title = b.Service?.Name ?? "Booking",
                            start = b.EventDate.Date.Add(b.StartTime.TimeOfDay).ToString("yyyy-MM-ddTHH:mm:ss"),
                            end = b.EventDate.Date.Add(b.EndTime.TimeOfDay).ToString("yyyy-MM-ddTHH:mm:ss"),
                            extendedProps = new {
                                bookingId = b.Id,
                                bookingCode = $"BK-{b.CreatedAt.Year}-{b.Id:D3}",
                                clientName = b.Client?.FullName ?? "N/A",
                                serviceName = b.Service?.Name ?? "N/A",
                                eventDate = b.EventDate.ToString("MMMM dd, yyyy"),
                                eventTime = $"{b.StartTime:hh:mm tt} - {b.EndTime:hh:mm tt}",
                                venue = b.PartyVenue ?? "N/A",
                                eventType = b.EventType ?? "N/A",
                                theme = b.PartyTheme ?? "N/A",
                                status = b.Status.ToString(),
                                statusKey = (b.Status == BookingStatus.Confirmed || b.Status == BookingStatus.Completed) ? "confirmed" : "pending",
                                paymentStatus = (b.Payments?.OrderByDescending(p => p.UploadedAt).FirstOrDefault()?.Status ?? "No Payment"),
                                detailsUrl = Url.Action("Details", "Bookings", new { id = b.Id })
                            }
                        })
                    )
                );

                calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    height: 'auto',
                    headerToolbar: false, // We use custom header
                    events: events,
                    dayMaxEvents: true,
                    eventOrder: 'start',
                    eventClassNames: function(arg) {
                        return ['cal-event', 'cal-event-' + arg.event.extendedProps.statusKey];
                    },
                    eventContent: function(arg) {
                        const props = arg.event.extendedProps;
                        const wrap = document.createElement('div');
                        wrap.className = 'cal-event-inner';
                        wrap.innerHTML = `
                            <span class="cal-event-time">${arg.timeText}</span>
                            <span class="cal-event-title">${props.serviceName}</span>
                        `;
                        return { domNodes: [wrap] };
                    },
                    eventDidMount: function(info) {
                        const props = info.event.extendedProps;
                        const tooltipHtml = `
                            <div class="cal-tooltip">
                                <div class="cal-tooltip-title">${props.bookingCode} &middot; ${props.serviceName}</div>
                                <div class="cal-tooltip-row"><i class="bi bi-person"></i> ${props.clientName}</div>
                                <div class="cal-tooltip-row"><i class="bi bi-box-seam"></i> ${props.serviceName}</div>
                                <div class="cal-tooltip-row"><i class="bi bi-calendar-event"></i> ${props.eventDate}</div>
                                <div class="cal-tooltip-row"><i class="bi bi-clock"></i> ${props.eventTime}</div>
                                <div class="cal-tooltip-row"><i class="bi bi-flag"></i> Status: ${props.status}</div>
                                <div class="cal-tooltip-row"><i class="bi bi-credit-card"></i> Payment: ${props.paymentStatus}</div>
                            </div>
                        `;
                        info.el.setAttribute('data-bs-toggle', 'tooltip');
                        info.el.setAttribute('data-bs-html', 'true');
                        info.el.setAttribute('data-bs-placement', 'top');
                        info.el.setAttribute('data-bs-custom-class', 'cal-tooltip-popover');
                        info.el.setAttribute('title', tooltipHtml);
                        new bootstrap.Tooltip(info.el, { trigger: 'hover focus' });
                    },
                    dayCellDidMount: function(info) {
                        const dateKey = formatDateKey(info.date);
                        const top = info.el.querySelector('.fc-daygrid-day-top');

                        // Blocked date
                        const blockedEntry = blockedDates.find(x => x.date === dateKey);
                        if (blockedEntry) {
                            info.el.classList.add('fc-day-blocked');
                            info.el.setAttribute('title', blockedEntry.reason ? `Blocked: ${blockedEntry.reason}` : 'Blocked date');
                            if (top) {
                                const badge = document.createElement('div');
                                badge.className = 'fc-day-badge fc-badge-blocked';
                                badge.innerHTML = '<i class="bi bi-x-lg"></i>';
                                badge.setAttribute('title', blockedEntry.reason ? `Blocked: ${blockedEntry.reason}` : 'Blocked date');
                                top.appendChild(badge);
                            }
                        }

                        // Custom limit
                        if (dateLimits[dateKey] !== undefined && top) {
                            info.el.classList.add('fc-day-limited');
                            const badge = document.createElement('div');
                            badge.className = 'fc-day-badge fc-badge-limit';
                            badge.innerHTML = `<i class="bi bi-exclamation-lg"></i> Max: ${dateLimits[dateKey]}`;
                            badge.setAttribute('title', `Custom daily limit: ${dateLimits[dateKey]} event(s)`);
                            top.appendChild(badge);
                        }

                        // Booking count
                        if (dailyCounts[dateKey] && top) {
                            const badge = document.createElement('div');
                            badge.className = 'fc-day-badge fc-badge-count';
                            badge.innerHTML = `${dailyCounts[dateKey]}`;
                            badge.setAttribute('title', `${dailyCounts[dateKey]} booking(s)`);
                            top.appendChild(badge);
                        }
                    },
                    dateClick: function(info) {
                        const dateKey = info.dateStr;
                        const blockedEntry = blockedDates.find(x => x.date === dateKey);

                        if (blockedEntry) {
                            // Show blocked date info in a toast or small modal
                            showToast(`Blocked: ${blockedEntry.reason || 'No reason provided'}`, 'info');
                        }
                    }
                });

                calendar.render();

                // Custom header navigation
                document.getElementById('calPrev')?.addEventListener('click', () => calendar.prev());
                document.getElementById('calNext')?.addEventListener('click', () => calendar.next());
                document.getElementById('calToday')?.addEventListener('click', () => calendar.today());

                // Update title
                updateCalendarTitle();

                // Listen for view changes
                calendar.on('datesSet', updateCalendarTitle);
            }

            function updateCalendarTitle() {
                if (!calendar) return;
                const view = calendar.view;
                const titleEl = document.getElementById('calendarTitle');
                if (titleEl) {
                    const start = view.currentStart;
                    titleEl.textContent = start.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
                }
            }

            // Toast notification
            function showToast(message, type = 'info') {
                const container = getOrCreateToastContainer();
                const toast = document.createElement('div');
                toast.className = `toast align-items-center text-white bg-${type === 'error' ? 'danger' : type === 'success' ? 'success' : 'primary'} border-0`;
                toast.setAttribute('role', 'alert');
                toast.setAttribute('aria-live', 'assertive');
                toast.setAttribute('aria-atomic', 'true');
                toast.innerHTML = `
                    <div class="d-flex">
                        <div class="toast-body">${message}</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                `;
                container.appendChild(toast);
                const bsToast = new bootstrap.Toast(toast, { delay: 3000 });
                bsToast.show();
                toast.addEventListener('hidden.bs.toast', () => toast.remove());
            }

            function getOrCreateToastContainer() {
                let container = document.getElementById('toastContainer');
                if (!container) {
                    container = document.createElement('div');
                    container.id = 'toastContainer';
                    container.className = 'toast-container position-fixed bottom-0 end-0 p-3';
                    container.style.zIndex = '9999';
                    document.body.appendChild(container);
                }
                return container;
            }

            // Initialize manage forms
            function initManageForms() {
                // Daily Limit Form
                document.getElementById('formDailyLimit')?.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const btn = e.target.querySelector('button[type="submit"]');
                    const originalText = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving...';
                    await submitForm('formDailyLimit', 'Daily limit updated successfully.');
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                });

                // Block Date Form
                document.getElementById('formBlockDate')?.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const btn = e.target.querySelector('button[type="submit"]');
                    const originalText = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Blocking...';
                    await submitForm('formBlockDate', 'Date blocked successfully.');
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                });

                // Custom Limit Form
                document.getElementById('formCustomLimit')?.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const btn = e.target.querySelector('button[type="submit"]');
                    const originalText = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving...';
                    await submitForm('formCustomLimit', 'Custom limit saved successfully.');
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                });
            }

            // Initialize delete buttons
            function initDeleteButtons() {
                document.querySelectorAll('.delete-item').forEach(btn => {
                    btn.addEventListener('click', function() {
                        pendingDelete.action = this.dataset.action;
                        pendingDelete.id = this.dataset.id;
                        const confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
                        const itemEl = this.closest('.list-item');
                        const dateText = itemEl?.querySelector('.list-item-date')?.textContent || 'this item';
                        document.getElementById('confirmMessage').textContent = `Are you sure you want to delete ${dateText}? This action cannot be undone.`;
                        confirmModal.show();
                    });
                });

                document.getElementById('confirmAction')?.addEventListener('click', async function() {
                    if (pendingDelete.action && pendingDelete.id) {
                        this.disabled = true;
                        this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Deleting...';
                        await deleteItem(pendingDelete.action, pendingDelete.id);
                        this.disabled = false;
                        this.innerHTML = 'Delete';
                        bootstrap.Modal.getInstance(document.getElementById('confirmModal'))?.hide();
                    }
                });
            }

            // Form validation
            function initFormValidation() {
                const forms = document.querySelectorAll('.needs-validation');
                forms.forEach(form => {
                    form.addEventListener('submit', function(e) {
                        if (!form.checkValidity()) {
                            e.preventDefault();
                            e.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            }

            // Page-level message container
            function ensurePageMessageContainer() {
                if (!document.getElementById('pageMessage')) {
                    const container = document.createElement('div');
                    container.id = 'pageMessage';
                    container.className = 'position-fixed top-0 start-50 translate-middle-x mt-3';
                    container.style.zIndex = '9999';
                    container.style.maxWidth = '90vw';
                    document.body.appendChild(container);
                }
            }

            // Initialize everything
            document.addEventListener('DOMContentLoaded', function() {
                ensurePageMessageContainer();
                initCalendar();
                initManageForms();
                initDeleteButtons();
                initFormValidation();

                // Bootstrap tooltip initialization
                const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
                tooltipTriggerList.map(function(tooltipTriggerEl) {
                    return new bootstrap.Tooltip(tooltipTriggerEl);
                });

                // Clear manage modal message when switching tabs
                document.querySelectorAll('#manageTabs button[data-bs-toggle="tab"]').forEach(tab => {
                    tab.addEventListener('shown.bs.tab', () => hideMessage());
                });

                // Reset block date form min date when opening
                document.getElementById('tab-block')?.addEventListener('shown.bs.tab', () => {
                    const input = document.getElementById('BlockDate');
                    if (input) input.min = new Date().toISOString().split('T')[0];
                });

                document.getElementById('tab-custom')?.addEventListener('shown.bs.tab', () => {
                    const input = document.getElementById('LimitDate');
                    if (input) input.min = new Date().toISOString().split('T')[0];
                });
            });
        })();
    </script>
}