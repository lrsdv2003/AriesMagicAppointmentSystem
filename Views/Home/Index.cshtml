<section class="landing-section">
    <div class="container">
        <div class="section-heading centered-heading">
            <span class="section-kicker">Perfect For</span>
            <h2>Events We Can Cater</h2>
            <p>
                Aries Magic can bring entertainment and excitement to different kinds of celebrations and gatherings.
            </p>
        </div>

        <div class="event-type-grid">
            <div class="event-type-card">Birthday</div>
            <div class="event-type-card">Company Events</div>
            <div class="event-type-card">Bridal Shower</div>
            <div class="event-type-card">Gender Reveal</div>
