@{
    ViewData["Title"] = "Home";
}

<section class="client-hero-section">
    <div class="client-hero-overlay"></div>
    <div class="container client-hero-content">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <div class="hero-badge">Professional Event Entertainment</div>
                <h1 class="client-hero-title">
                    Bring Magic, Fun, and Memorable Moments to Every Celebration
                </h1>
                <p class="client-hero-text">
                    Aries Magic delivers interactive entertainment for birthdays, school programs,
                    company events, and special celebrations through illusion magic, ventriloquism,
                    bubble shows, and audience participation experiences.
                </p>

                <div class="client-hero-actions">
                    <a asp-controller="Bookings" asp-action="CreateStepOne" class="btn btn-primary btn-lg">
                        Book Now
                    </a>
                    <a href="#packages" class="btn btn-outline-light btn-lg">
                        View Packages
                    </a>
                </div>

                <div class="hero-trust-row">
                    <div class="hero-trust-item">
                        <strong>Interactive Performances</strong>
                        <span>Entertainment for kids and adults</span>
                    </div>
                    <div class="hero-trust-item">
                        <strong>Easy Online Booking</strong>
                        <span>Simple and organized workflow</span>
                    </div>
                    <div class="hero-trust-item">
                        <strong>Event Ready Packages</strong>
                        <span>Flexible choices for different occasions</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="hero-highlight-card">
                    <div class="hero-highlight-top">
                        <span class="hero-highlight-label">Featured Package</span>
                        <h3>All In Package</h3>
                    </div>

                    <p class="hero-highlight-description">
                        A complete entertainment experience that combines hosting, illusion magic,
                        audience interaction, ventriloquism, and bubble show highlights for a more
                        premium celebration.
                    </p>

                    <ul class="hero-highlight-list">
                        <li>Professional Party Host</li>
                        <li>Interactive Magic & Comedy Magic</li>
                        <li>Grand Illusion Highlights</li>
                        <li>Bubble Show Entertainment</li>
                        <li>Audience Participation Activities</li>
                    </ul>

                    <div class="hero-highlight-footer">
                        <span class="hero-highlight-price">Starts at ₱24,500</span>
                        <a asp-controller="Bookings" asp-action="CreateStepOne" class="btn btn-light">
                            Choose Package
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="landing-section">
    <div class="container">
        <div class="section-heading centered-heading">
            <span class="section-kicker">Why Choose Aries Magic</span>
            <h2>Entertainment That Adds Energy, Wonder, and Joy</h2>
            <p>
                From private celebrations to school and company events, Aries Magic creates
                performances that keep guests engaged, entertained, and excited from start to finish.
            </p>
        </div>

        <div class="landing-feature-grid">
            <div class="landing-feature-card">
                <div class="feature-icon-circle">🎩</div>
                <h4>Professional Event Experience</h4>
                <p>
                    Enjoy a more complete entertainment setup led by a skilled host and performer
                    who keeps the program lively, organized, and enjoyable.
                </p>
            </div>

            <div class="landing-feature-card">
                <div class="feature-icon-circle">✨</div>
                <h4>Flexible Package Options</h4>
                <p>
                    Choose the package that fits your event best and customize selected removable
                    inclusions based on your needs and budget.
                </p>
            </div>

            <div class="landing-feature-card">
                <div class="feature-icon-circle">📅</div>
                <h4>Organized Booking Workflow</h4>
                <p>
                    Submit your request online, monitor updates, upload payment proof, and receive
                    confirmation through a clearer and more organized system.
                </p>
            </div>
        </div>
    </div>
</section>

<section id="packages" class="landing-section light-section">
    <div class="container">
        <div class="section-heading centered-heading">
            <span class="section-kicker">Our Packages</span>
            <h2>Choose the Right Package for Your Event</h2>
            <p>
                Explore our entertainment packages and choose the one that best matches your celebration.
            </p>
        </div>

        <div class="package-landing-grid">
            <div class="package-landing-card">
                <div class="package-tag">Popular Choice</div>
                <h3>Premium Package</h3>
                <div class="package-landing-price">₱19,800</div>
                <p class="package-landing-description">
                    A strong entertainment package with illusion magic, audience interaction,
                    comedy magic, and live animal show highlights.
                </p>
                <ul class="package-landing-list">
                    <li>Professional Party Host</li>
                    <li>Game Facilitator</li>
                    <li>Ventriloquism</li>
                    <li>Illusion Magic Performance</li>
                    <li>Audience Participation</li>
                </ul>
                <a asp-controller="Bookings" asp-action="CreateStepOne" class="btn btn-outline-primary w-100">
                    Book Premium
                </a>
            </div>

            <div class="package-landing-card featured-package-card">
                <div class="package-tag featured-tag">Best Value</div>
                <h3>Deluxe Package</h3>
                <div class="package-landing-price">₱20,000</div>
                <p class="package-landing-description">
                    A fun-filled celebration package featuring hosting, magic entertainment,
                    ventriloquism, and a bubble show experience.
                </p>
                <ul class="package-landing-list">
                    <li>Professional Party Host</li>
                    <li>Game Facilitator</li>
                    <li>Professional Magician</li>
                    <li>Ventriloquism</li>
                    <li>Bubble Show Experience</li>
                </ul>
                <a asp-controller="Bookings" asp-action="CreateStepOne" class="btn btn-primary w-100">
                    Book Deluxe
                </a>
            </div>

            <div class="package-landing-card">
                <div class="package-tag">Full Experience</div>
                <h3>All In Package</h3>
                <div class="package-landing-price">₱24,500</div>
                <p class="package-landing-description">
                    A premium entertainment package that combines illusion magic and bubble show
                    highlights for a more complete celebration experience.
                </p>
                <ul class="package-landing-list">
                    <li>Professional Party Host</li>
                    <li>Ventriloquism</li>
                    <li>Illusion Magic</li>
                    <li>Bubble Show Highlights</li>
                    <li>Premium Event Experience</li>
                </ul>
                <a asp-controller="Bookings" asp-action="CreateStepOne" class="btn btn-outline-primary w-100">
                    Book All In
                </a>
            </div>
        </div>
    </div>
</section>

