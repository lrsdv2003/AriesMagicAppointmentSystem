<section id="how-it-works" class="landing-section light-section">
    <div class="container">
        <div class="section-heading centered-heading">
            <span class="section-kicker">How It Works</span>
            <h2>Simple Booking in Just a Few Steps</h2>
            <p>
                Our system makes it easier to request, customize, and confirm bookings online.
            </p>
        </div>

        <div class="how-it-works-grid">
            <div class="how-card">
                <div class="how-step-number">1</div>
                <h4>Fill Out Event Details</h4>
                <p>Enter your event information such as date, time, venue, celebrant, and contact details.</p>
            </div>

            <div class="how-card">
                <div class="how-step-number">2</div>
                <h4>Select and Customize Package</h4>
                <p>Choose a package and remove selected inclusions based on your event needs and budget.</p>
            </div>

            <div class="how-card">
                <div class="how-step-number">3</div>
                <h4>Wait for Booking Review</h4>
                <p>Your booking request will be reviewed by the staff before moving to the next stage.</p>
            </div>

            <div class="how-card">
                <div class="how-step-number">4</div>
                <h4>Upload Downpayment</h4>
                <p>After approval, upload your payment proof for the required ₱2,000 downpayment.</p>
            </div>
        </div>
    </div>
</section>

<section class="landing-section">
    <div class="container">
        <div class="cta-banner">
            <div>
                <span class="section-kicker">Ready to Book?</span>
                <h2>Bring Magic and Fun to Your Next Celebration</h2>
                <p>
                    Start your booking today and choose the package that best matches your event.
                </p>
            </div>

            <div class="cta-banner-actions">
                <a asp-controller="Bookings" asp-action="CreateStepOne" class="btn btn-primary btn-lg">
                    Start Booking
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg">
                    Create Account
                </a>
            </div>
        </div>
    </div>
</section>