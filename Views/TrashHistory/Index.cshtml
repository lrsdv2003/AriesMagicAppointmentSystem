@model AriesMagicAppointmentSystem.ViewModels.TrashHistoryIndexViewModel
@using AriesMagicAppointmentSystem.Models

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Trash History";
    var f = Model?.Filters;
    var hasActiveFilters = f != null && (
        f.Reason.HasValue || 
        (f.PaymentStatus != null && f.PaymentStatus != "All") || 
        !string.IsNullOrEmpty(f.AssignedStaffId) || 
        f.DateFrom.HasValue || 
        f.DateTo.HasValue
    );
}


<div class="dashboard-panel mb-4">
    <form method="get" asp-action="Index">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            
            <!-- Direct Search Input -->
            <div class="flex-grow-1" style="max-width: 400px;">
                <div class="input-group">
                    <span class="input-group-text bg-white text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="Search" value="@f?.Search" class="form-control border-start-0"
                           placeholder="Booking ID, client, package, event type..." />
                </div>
            </div>

            <!-- Floating Filter Popover Dropdown -->
            <div class="dropdown filter-dropdown-wrapper">
                <button class="btn btn-outline-secondary dropdown-toggle d-flex align-items-center gap-2" 
                        type="button" 
                        id="trashFilterDropdown" 
                        data-bs-toggle="dropdown" 
                        data-bs-auto-close="outside" 
                        aria-expanded="false">
                    <i class="bi bi-funnel"></i>
                    <span>Filters</span>
                    @if (hasActiveFilters)
                    {
                        <span class="filter-active-dot"></span>
                    }
                </button>

                <!-- Floating Card Content -->
                <div class="dropdown-menu dropdown-menu-end filter-popover-menu" 
                     aria-labelledby="trashFilterDropdown" 
                     style="width: 350px;">
                    
                    <h6 class="fw-bold mb-3">Filter Archived Requests</h6>
                    
                    <div class="mb-3">
                        <label class="form-label">Reason</label>
                        <select name="Reason" class="form-select form-select-sm">
                            <option value="">All Reasons</option>
                            @foreach (TrashReason reason in Enum.GetValues(typeof(TrashReason)))
                            {
                                <option value="@((int)reason)" selected="@(f?.Reason == reason)">@reason</option>
                            }
                        </select>
                    </div>


                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label">From Date</label>
                            <input type="date" name="DateFrom" value="@(f?.DateFrom?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">To Date</label>
                            <input type="date" name="DateTo" value="@(f?.DateTo?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <hr class="my-3" />

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light btn-sm">Reset</a>
                        <button type="submit" class="btn btn-primary btn-sm">Apply Filters</button>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <button type="submit" class="btn btn-primary">Search</button>

            @if (f != null && (!string.IsNullOrEmpty(f.Search) || hasActiveFilters))
            {
                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted">Clear all</a>
            }
        </div>
    </form>
</div>

<div class="dashboard-panel">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h3 class="mb-1">Archived Requests</h3>
            <p class="page-subtitle mb-0">Showing @(Model?.Bookings?.Count ?? 0) of @(Model?.TotalCount ?? 0) archived request(s).</p>
        </div>
    </div>

    @if (Model?.Bookings == null || !Model.Bookings.Any())
    {
        <div class="empty-state">
            <i class="bi bi-trash"></i>
            <h3>No archived requests</h3>
            
        </div>
    }
    else
    {
        <div class="table-clean">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Booking ID</th>
                        <th>Client</th>
                        <th>Event Type</th>
                        <th>Package</th>
                        <th>Event Date</th>
                        <th>Reason</th>
                        <th>Payment</th>
                        <th>Archived</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Bookings)
                    {
                        var paymentClass = item.PaymentStatus switch
                        {
                            "Pending" => "status-pending",
                            "Verified" => "status-verified",
                            "Rejected" => "status-rejected",
                            _ => "status-read"
                        };

                        <tr>
                            <td><div class="booking-code-cell">@item.BookingCode</div></td>
                            <td>
                                <div class="fw-semibold">@item.ClientName</div>
                                <div class="text-muted small">@item.ClientPhone</div>
                            </td>
                            <td>@item.EventType</td>
                            <td>@item.PackageName</td>
                            <td>@item.EventDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge bg-secondary">@item.ReasonDisplay</span>
                                @if (!string.IsNullOrWhiteSpace(item.ReasonNotes))
                                {
                                    <span class="text-muted small d-block">@item.ReasonNotes</span>
                                }
                            </td>
                            <td><span class="status-badge @paymentClass">@item.PaymentStatus</span></td>
                            <td>@item.ArchivedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye me-1"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == f?.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@p"
                               asp-route-Search="@f?.Search"
                               asp-route-Reason="@(f?.Reason?.ToString("d"))"
                               asp-route-PaymentStatus="@f?.PaymentStatus"
                               asp-route-AssignedStaffId="@f?.AssignedStaffId"
                               asp-route-DateFrom="@(f?.DateFrom?.ToString("yyyy-MM-dd"))"
                               asp-route-DateTo="@(f?.DateTo?.ToString("yyyy-MM-dd"))">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>