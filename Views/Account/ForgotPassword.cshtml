@model AriesMagicAppointmentSystem.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<section class="auth-section">
    <div class="auth-card">
        <div class="auth-header">
            <span class="hero-badge">Account Recovery</span>
            <h1>Forgot Your Password?</h1>
            <p>
                Enter your email address to continue resetting your password.
            </p>
        </div>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Continue</button>
                <a asp-controller="Account" asp-action="Login" class="btn btn-secondary">Back to Login</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}