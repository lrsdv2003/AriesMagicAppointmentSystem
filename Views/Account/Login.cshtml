@model AriesMagicAppointmentSystem.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-page">
    <div class="auth-shell">
        <div class="auth-left">
            <div class="auth-brand-badge">Aries Magic</div>
            <h1 class="auth-hero-title">Welcome Back</h1>
            <p class="auth-hero-text">
                Sign in to manage your bookings, upload payment proof, track updates,
                and continue your event booking journey with Aries Magic.
            </p>

            <div class="auth-feature-list">
                <div class="auth-feature-item">
                    <span class="auth-feature-icon">✨</span>
                    <div>
                        <strong>Track Booking Status</strong>
                        <p>Stay updated on your request from submission to confirmation.</p>
                    </div>
                </div>

                <div class="auth-feature-item">
                    <span class="auth-feature-icon">📩</span>
                    <div>
                        <strong>Email-based Security</strong>
                        <p>Use secure account recovery and email verification features.</p>
                    </div>
                </div>

                <div class="auth-feature-item">
                    <span class="auth-feature-icon">🎉</span>
                    <div>
                        <strong>Simple Booking Flow</strong>
                        <p>Book packages, customize inclusions, and manage event details online.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-right">
            <div class="auth-card">
                <div class="auth-card-header">
                    <h2>Login to Your Account</h2>
                    <p>Access your client account and continue your booking process.</p>
                </div>

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="auth-form-row mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <a asp-action="ForgotPassword" class="auth-link">Forgot Password?</a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 auth-submit-btn">Login</button>
                </form>

                <div class="auth-divider">
                    <span>New here?</span>
                </div>

                <a asp-action="Register" class="btn btn-outline-primary w-100">Create Client Account</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}