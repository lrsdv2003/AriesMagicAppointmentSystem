@model AriesMagicAppointmentSystem.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<section class="auth-section">
    <div class="auth-card">
        <div class="auth-header">
            <span class="hero-badge">Welcome Back</span>
            <h1>Login to Your Account</h1>
            <p>
                Access your bookings, payments, notifications, and reschedule requests.
            </p>
        </div>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-3">
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mb-3">
                @TempData["ErrorMessage"]
            </div>
        }
        <form asp-controller="Account" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Login</button>
            </div>
        </form>

        <div class="auth-footer-text">
            <p class="mb-1">
                <a asp-controller="Account" asp-action="ForgotPassword">Forgot Password?</a>
            </p>
            <p class="mb-0">
                Don’t have an account yet?
                <a asp-controller="Account" asp-action="Register">Create one here</a>
            </p>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}