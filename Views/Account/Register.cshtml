@model AriesMagicAppointmentSystem.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="auth-page">
    <div class="auth-shell">
        <div class="auth-left">
            <div class="auth-brand-badge">Aries Magic</div>
            <h1 class="auth-hero-title">Create Your Client Account</h1>
            <p class="auth-hero-text">
                Register to start booking event packages, customize your package inclusions,
                monitor your booking progress, and receive important updates through email.
            </p>

            <div class="auth-feature-list">
                <div class="auth-feature-item">
                    <span class="auth-feature-icon">📅</span>
                    <div>
                        <strong>Easy Online Booking</strong>
                        <p>Submit event details and choose the package that fits your celebration.</p>
                    </div>
                </div>

                <div class="auth-feature-item">
                    <span class="auth-feature-icon">💳</span>
                    <div>
                        <strong>Organized Payment Workflow</strong>
                        <p>Upload payment proof and receive verification updates through the system.</p>
                    </div>
                </div>

                <div class="auth-feature-item">
                    <span class="auth-feature-icon">🔐</span>
                    <div>
                        <strong>Protected Client Access</strong>
                        <p>Use a verified email and secure password recovery for your account.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-right">
            <div class="auth-card auth-card-large">
                <div class="auth-card-header">
                    <h2>Create Client Account</h2>
                    <p>Fill in your details to register and begin your booking process.</p>
                </div>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="09XXXXXXXXX" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" placeholder="Create password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 auth-submit-btn mt-4">Create Account</button>
                </form>

                <div class="auth-divider">
                    <span>Already have an account?</span>
                </div>

                <a asp-action="Login" class="btn btn-outline-primary w-100">Back to Login</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}