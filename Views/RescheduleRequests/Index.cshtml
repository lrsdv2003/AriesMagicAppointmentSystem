@model IEnumerable<AriesMagicAppointmentSystem.Models.RescheduleRequest>

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Reschedule Requests";

    var requests = Model.OrderByDescending(x => x.CreatedAt).ToList();
    var totalRequests = requests.Count;
    var pendingCount = requests.Count(x => x.Status == AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Pending);
    var approvedCount = requests.Count(x => x.Status == AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Approved);
    var rejectedCount = requests.Count(x => x.Status == AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Rejected);
}

<div class="page-header">
</div>

<div class="dashboard-stats mb-4">
    <div class="stat-card">
        <div class="stat-label">Total Requests</div>
        <div class="stat-value">@totalRequests</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-label">Approved</div>
        <div class="stat-value">@approvedCount</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Rejected</div>
        <div class="stat-value">@rejectedCount</div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["Error"]</div>
}

<!-- FILTER & SEARCH BAR SECTION (LIKE IMAGE 2) -->
<div class="dashboard-panel mb-4 p-3 rounded-4 bg-white shadow-sm border">
    <form method="get" asp-action="Index" class="d-flex align-items-center gap-2 flex-wrap">
        <div class="flex-grow-1">
            <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control rounded-pill px-3" placeholder="Search client, email, or service...">
        </div>

        <!-- DROPDOWN FILTER BUTTON -->
        <div class="dropdown">
            <button class="btn btn-outline-secondary rounded-pill px-3 dropdown-toggle d-flex align-items-center gap-2" type="button" id="filterDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                <i class="bi bi-funnel"></i> Filters
            </button>

            <!-- DROPDOWN POPOVER PANEL -->
            <div class="dropdown-menu p-4 rounded-4 shadow-lg border-0 style-filter-panel" aria-labelledby="filterDropdown" style="width: 320px;">
                <h5 class="fw-bold mb-3">Filter Requests</h5>

                <div class="mb-3">
                    <label class="form-label small text-muted fw-bold text-uppercase">Status</label>
                    <select name="status" class="form-select rounded-3">
                        <option value="">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label small text-muted fw-bold text-uppercase">Requested Date</label>
                    <input type="date" name="requestedDate" value="@Context.Request.Query["requestedDate"]" class="form-control rounded-3" />
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted fw-bold text-uppercase">Sort By</label>
                    <select name="sortBy" class="form-select rounded-3">
                        <option value="newest">Newest</option>
                        <option value="oldest">Oldest</option>
                    </select>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-3">Reset</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-3">Apply Filters</button>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary rounded-pill px-4">
            Search
        </button>
    </form>
</div>

<div class="dashboard-panel">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h3 class="mb-1">Reschedule Request Records</h3>
            <p class="page-subtitle mb-0">Showing @requests.Count request(s) in the current queue.</p>
        </div>
    </div>

    @if (!requests.Any())
    {
        <div class="empty-state">
            <h3>No reschedule requests found</h3>
        </div>
    }
    else
    {
        <div class="table-clean reschedule-table-wrap">
            <table class="table align-middle reschedule-management-table">
                <thead>
                    <tr>
                        <th>Client</th>
                        <th>Service</th>
                        <th>Original Date</th>
                        <th>Requested Date</th>
                        <th>Requested Start</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in requests)
                    {
                        var statusClass = item.Status switch
                        {
                            AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Pending => "status-pending",
                            AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Approved => "status-approved",
                            AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Rejected => "status-rejected",
                            _ => "status-read"
                        };

                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Booking?.Client?.FullName</div>
                                <div class="text-muted small">@item.Booking?.Client?.Email</div>
                            </td>
                            <td>@item.Booking?.Service?.Name</td>
                            <td>@(item.Booking?.EventDate.ToString("MMM dd, yyyy") ?? "N/A")</td>
                            <td>@item.RequestedDate.ToString("MMM dd, yyyy")</td>
                            <td>@item.RequestedStartTime.ToString("hh:mm tt")</td>
                            <td>
                                <span class="status-badge @statusClass">@item.Status</span>
                            </td>
                            <td class="text-end">
                                <div class="reschedule-action-group">
                                    @if (item.Status == AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Pending && User.CanApproveRescheduleRequests())
                                    {
                                        <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success">Approve</a>
                                        <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Reject</a>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled>No Action Needed</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>