@model IEnumerable<AriesMagicAppointmentSystem.Models.RescheduleRequest>

@{
    ViewData["Title"] = "Reschedule Requests";
}

<div class="page-header">
    <div>
        <h1>Reschedule Requests</h1>
        <p class="page-subtitle">Review client reschedule requests.</p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["Error"]</div>
}

<div class="table-clean">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Client</th>
                <th>Service</th>
                <th>Requested Date</th>
                <th>Requested Start</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
            <tr>
                <td>@item.Booking?.Client?.FullName</td>
                <td>@item.Booking?.Service?.Name</td>
                <td>@item.RequestedDate.ToString("MMM dd, yyyy")</td>
                <td>@item.RequestedStartTime.ToString("hh:mm tt")</td>
                <td><span class="status-badge">@item.Status</span></td>
                <td class="text-end">
                    @if (item.Status == AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Pending)
                    {
                        <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success">Approve</a>
                        <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Reject</a>
                    }
                </td>
            </tr>
}
        </tbody>
    </table>
</div>