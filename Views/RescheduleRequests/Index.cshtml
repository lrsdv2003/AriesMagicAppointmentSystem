@model IEnumerable<AriesMagicAppointmentSystem.Models.RescheduleRequest>

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Reschedule Requests";
}

<div class="dashboard-stats">
    <div class="stat-card">
        <div class="stat-label">Total Requests</div>
        <div class="stat-value">@Model.Count()</div>
        <div class="stat-subtext">All client reschedule requests currently recorded.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Pending Review</div>
        <div class="stat-value">@Model.Count(x => x.Status == AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Pending)</div>
        <div class="stat-subtext">Requests still waiting for final admin action.</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Decision Stage</div>
        <div class="stat-value">Admin</div>
        <div class="stat-subtext">Approve or reject requests while checking schedule conflicts.</div>
    </div>
</div>

<div class="page-header">
    <div>
        <h1>Reschedule Requests</h1>
        <p class="page-subtitle">Review client requests to change their booking schedule.</p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["Error"]</div>
}

<div class="table-clean">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Client</th>
                <th>Service</th>
                <th>Requested Date</th>
                <th>Requested Start</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
            <tr>
                <td>@item.Booking?.Client?.FullName</td>
                <td>@item.Booking?.Service?.Name</td>
                <td>@item.RequestedDate.ToString("MMM dd, yyyy")</td>
                <td>@item.RequestedStartTime.ToString("hh:mm tt")</td>
                <td><span class="status-badge">@item.Status</span></td>
                <td class="text-end">
                    @if (item.Status == AriesMagicAppointmentSystem.Models.RescheduleRequestStatus.Pending)
                    {
                        <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success">Approve</a>
                        <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Reject</a>
                    }
                </td>
            </tr>
}
        </tbody>
    </table>
</div>