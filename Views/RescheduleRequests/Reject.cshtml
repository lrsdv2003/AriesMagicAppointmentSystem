@model AriesMagicAppointmentSystem.Models.RescheduleRequest

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Reject Reschedule";
}

<div class="page-header">
    <div>
        <h1>Reject Reschedule</h1>
        <p class="page-subtitle">Review the request details and provide remarks before rejecting this reschedule request.</p>
    </div>
</div>

<div class="booking-details-layout">
    <div class="dashboard-panel">
        <div class="form-section-title mb-3">Request Information</div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Client</span>
                    <span class="package-meta-value">@Model.Booking?.Client?.FullName</span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Service</span>
                    <span class="package-meta-value">@Model.Booking?.Service?.Name</span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Original Date</span>
                    <span class="package-meta-value">@Model.Booking?.EventDate.ToString("MMMM dd, yyyy")</span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Original Start Time</span>
                    <span class="package-meta-value">@Model.Booking?.StartTime.ToString("hh:mm tt")</span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Requested Date</span>
                    <span class="package-meta-value">@Model.RequestedDate.ToString("MMMM dd, yyyy")</span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="package-meta-box h-100">
                    <span class="package-meta-label">Requested Start Time</span>
                    <span class="package-meta-value">@Model.RequestedStartTime.ToString("hh:mm tt")</span>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <div class="form-section-title mb-2">Client Reason</div>
            <div class="details-description-block">
                @Model.Reason
            </div>
        </div>
    </div>

    <div class="dashboard-panel">
        <div class="form-section-title mb-3">Rejection Decision</div>
        <p class="page-subtitle mb-3">Add remarks to explain why this reschedule request is being rejected.</p>

        <form asp-action="Reject" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-4">
                <label class="form-label">Admin Remarks</label>
                <textarea name="adminRemarks"
                          class="form-control"
                          rows="5"
                          placeholder="Add remarks for this rejection decision"></textarea>
            </div>

            <div class="booking-summary-note mb-4">
                Give a clear reason so the client understands why the request could not be approved.
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-danger">Reject Request</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>