@model AriesMagicAppointmentSystem.ViewModels.RescheduleRequestCreateViewModel

@{
    ViewData["Title"] = "Request Reschedule";
    var unavailableDates = ViewBag.UnavailableDates as List<string> ?? new List<string>();
    var unavailableDatesJson = System.Text.Json.JsonSerializer.Serialize(unavailableDates);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />

<div class="client-portal-header">
    <div>
        <div class="section-kicker">Client Portal</div>
        <h1 class="client-portal-title">Request Reschedule</h1>
        <p class="client-portal-text">Choose a new preferred schedule for your existing booking.</p>
    </div>
</div>

<div class="dashboard-panel mb-4">
    <div class="form-section-title mb-2">Availability Guide</div>
    <p class="availability-help mb-3">
        Some dates may be unavailable because they are already full or blocked by the admin.
        All packages last <strong>3 hours</strong> and include a required <strong>1-hour buffer</strong> after the event.
    </p>

    <div class="availability-legend">
        <div class="availability-legend-item">
            <span class="availability-dot available"></span>
            <span>Available date</span>
        </div>
        <div class="availability-legend-item">
            <span class="availability-dot unavailable"></span>
            <span>Unavailable date</span>
        </div>
    </div>
</div>

<div class="dashboard-panel">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div id="dateAvailabilityAlert" class="alert alert-warning d-none mb-3">
            This selected date is unavailable for reschedule because it is either blocked or already at full capacity.
        </div>

        <div id="dateSlotsInfo" class="alert alert-info d-none mb-3"></div>

        <div id="timeConflictAlert" class="alert alert-danger d-none mb-3">
            The selected start time conflicts with an existing booking schedule.
        </div>

        <div id="unavailableTimeRangesBox" class="dashboard-panel mt-3 d-none">
            <div class="time-range-box-title">Unavailable Time Ranges</div>
            <p class="availability-help mb-2">
                These time ranges are unavailable because of confirmed bookings and the required 1-hour buffer.
            </p>
            <div id="unavailableTimeRangesList" class="time-range-chip-list"></div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-12">
                <label asp-for="BookingId" class="form-label">Select Booking</label>
                <select asp-for="BookingId" asp-items="Model.Bookings" class="form-select" id="bookingSelect">
                    <option value="">-- Select Booking --</option>
                </select>
                <span asp-validation-for="BookingId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="RequestedDate" class="form-label">Requested Date</label>
                <input asp-for="RequestedDate"
                       type="text"
                       class="form-control"
                       id="requestedDateInput"
                       autocomplete="off" />
                <span asp-validation-for="RequestedDate" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="RequestedStartTime" class="form-label">Requested Start Time</label>
                <input asp-for="RequestedStartTime" type="time" class="form-control" id="requestedStartTimeInput" />
                <span asp-validation-for="RequestedStartTime" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Reason" class="form-label">Reason</label>
                <textarea asp-for="Reason" class="form-control" rows="4" placeholder="Explain why you want to request a reschedule"></textarea>
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>
        </div>

        <div class="upload-payment-actions mt-4">
            <button type="submit" class="btn btn-primary btn-lg" id="submitRescheduleBtn">Submit Request</button>
            <a asp-action="MyRequests" class="btn btn-outline-secondary btn-lg">Back to My Requests</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const unavailableDates = @Html.Raw(unavailableDatesJson);
            const alertBox = document.getElementById("dateAvailabilityAlert");
            const slotsInfo = document.getElementById("dateSlotsInfo");
            const timeConflictAlert = document.getElementById("timeConflictAlert");
            const submitBtn = document.getElementById("submitRescheduleBtn");
            const dateInput = document.getElementById("requestedDateInput");
            const timeInput = document.getElementById("requestedStartTimeInput");
            const bookingSelect = document.getElementById("bookingSelect");
            const timeRangesBox = document.getElementById("unavailableTimeRangesBox");
            const timeRangesList = document.getElementById("unavailableTimeRangesList");

            let currentUnavailableRanges = [];

            function timeToMinutes(timeStr) {
                if (!timeStr) return -1;
                const [hours, minutes] = timeStr.split(":").map(Number);
                return (hours * 60) + minutes;
            }

            function checkTimeConflict() {
                const selectedTime = timeInput.value;

                if (!selectedTime || currentUnavailableRanges.length === 0) {
                    timeConflictAlert.classList.add("d-none");
                    submitBtn.disabled = false;
                    return;
                }

                const selectedMinutes = timeToMinutes(selectedTime);

                const hasConflict = currentUnavailableRanges.some(range => {
                    const start = timeToMinutes(range.start);
                    const end = timeToMinutes(range.end);
                    return selectedMinutes >= start && selectedMinutes < end;
                });

                if (hasConflict) {
                    timeConflictAlert.classList.remove("d-none");
                    submitBtn.disabled = true;
                } else {
                    timeConflictAlert.classList.add("d-none");
                    submitBtn.disabled = false;
                }
            }

            async function loadUnavailableTimeRanges(selectedDate) {
                timeRangesList.innerHTML = "";
                currentUnavailableRanges = [];
                timeRangesBox.classList.add("d-none");
                timeConflictAlert.classList.add("d-none");

                if (!selectedDate) return;

                const selectedBookingId = bookingSelect.value || "";

                try {
                    const response = await fetch(`/RescheduleRequests/GetUnavailableTimeRanges?date=${selectedDate}&excludeBookingId=${selectedBookingId}`);
                    const data = await response.json();

                    currentUnavailableRanges = data || [];

                    if (currentUnavailableRanges.length > 0) {
                        currentUnavailableRanges.forEach(range => {
                            const chip = document.createElement("div");
                            chip.className = "time-range-chip";
                            chip.textContent = range.display;
                            timeRangesList.appendChild(chip);
                        });

                        timeRangesBox.classList.remove("d-none");
                    }

                    checkTimeConflict();
                } catch (error) {
                    timeRangesBox.classList.add("d-none");
                }
            }

            async function loadDateAvailability(selectedDate) {
                if (!selectedDate) {
                    alertBox.classList.add("d-none");
                    slotsInfo.classList.add("d-none");
                    timeRangesBox.classList.add("d-none");
                    timeConflictAlert.classList.add("d-none");
                    submitBtn.disabled = false;
                    return;
                }

                try {
                    const response = await fetch(`/RescheduleRequests/CheckRescheduleDateAvailability?date=${selectedDate}`);
                    const data = await response.json();

                    if (data.isBlocked) {
                        const reasonText = data.blockReason ? ` Reason: ${data.blockReason}` : "";
                        alertBox.textContent = `This selected date is blocked by the admin.${reasonText}`;
                        alertBox.classList.remove("d-none");
                        slotsInfo.classList.add("d-none");
                        timeRangesBox.classList.add("d-none");
                        timeConflictAlert.classList.add("d-none");
                        submitBtn.disabled = true;
                        return;
                    }

                    if (data.isFull) {
                        alertBox.textContent = "This selected date is fully booked.";
                        alertBox.classList.remove("d-none");
                        slotsInfo.classList.add("d-none");
                        timeRangesBox.classList.add("d-none");
                        timeConflictAlert.classList.add("d-none");
                        submitBtn.disabled = true;
                        return;
                    }

                    alertBox.classList.add("d-none");
                    slotsInfo.classList.remove("slots-alert-good", "slots-alert-warning", "slots-alert-danger");

                    if (data.remainingSlots <= 0) {
                        slotsInfo.textContent = "No slots left for this date.";
                        slotsInfo.classList.add("slots-alert-danger");
                    } else if (data.remainingSlots === 1) {
                        slotsInfo.textContent = "Only 1 slot remains for this date.";
                        slotsInfo.classList.add("slots-alert-warning");
                    } else {
                        slotsInfo.textContent = `${data.remainingSlots} slots are still available out of ${data.maxPerDay}.`;
                        slotsInfo.classList.add("slots-alert-good");
                    }

                    slotsInfo.classList.remove("d-none");

                    await loadUnavailableTimeRanges(selectedDate);
                } catch (error) {
                    slotsInfo.classList.add("d-none");
                    timeRangesBox.classList.add("d-none");
                }
            }

            flatpickr("#requestedDateInput", {
                dateFormat: "Y-m-d",
                minDate: "today",
                disable: unavailableDates,
                defaultDate: dateInput.value || null,
                onChange: async function (selectedDates, dateStr) {
                    await loadDateAvailability(dateStr);
                },
                onReady: async function (selectedDates, dateStr) {
                    await loadDateAvailability(dateStr);
                }
            });

            timeInput.addEventListener("change", checkTimeConflict);

            bookingSelect.addEventListener("change", async function () {
                if (dateInput.value) {
                    await loadDateAvailability(dateInput.value);
                }
            });
        });
    </script>
}