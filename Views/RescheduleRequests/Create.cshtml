@model AriesMagicAppointmentSystem.ViewModels.RescheduleRequestCreateViewModel

@{
    ViewData["Title"] = "Request Reschedule";
}

<div class="page-header">
    <div>
        <h1>Request Reschedule</h1>
        <p class="page-subtitle">Submit a new requested date and time for your booking.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="BookingId" class="form-label"></label>
            <select asp-for="BookingId" asp-items="Model.Bookings" class="form-control">
                <option value="">-- Select Booking --</option>
            </select>
            <span asp-validation-for="BookingId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RequestedDate" class="form-label"></label>
            <input asp-for="RequestedDate"
                   type="date"
                   class="form-control"
                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
            <span asp-validation-for="RequestedDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RequestedStartTime" class="form-label"></label>
            <input asp-for="RequestedStartTime"
                   type="time"
                   class="form-control" />
            <span asp-validation-for="RequestedStartTime" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Reason" class="form-label"></label>
            <textarea asp-for="Reason" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Reason" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Submit Request</button>
            <a asp-action="MyRequests" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}